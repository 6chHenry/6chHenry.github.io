---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ContentCard from '../../components/ContentCard.astro';
import { buildContentUrl, formatRecencyDate, sortByRecency } from '../../utils/content';

const entries = sortByRecency(await getCollection('essay', ({ data }) => !data.draft));
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="杂谈 | 6ch. · 林间笔记" description="6ch. 的随笔与思考">
  <section class="container page-shell">
    <header class="page-header">
      <p class="section-kicker">Essays</p>
      <h1>杂谈</h1>
      <p class="section-lead">随笔、旅行与偶发念头 — 不必成体系，但值得留下。</p>
    </header>

    <ul class="content-list">
      {
        entries.map((entry) => (
          <li>
            <ContentCard
              href={buildContentUrl('essay', entry.id, base)}
              title={entry.data.title}
              description={entry.data.description ?? ''}
              date={formatRecencyDate(entry)}
              collection="essay"
            />
          </li>
        ))
      }
    </ul>
  </section>
</BaseLayout>
