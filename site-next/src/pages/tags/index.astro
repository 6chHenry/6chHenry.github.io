---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { collectTags } from '../../utils/content';

const [notes, essays, projects] = await Promise.all([
  getCollection('notes', ({ data }) => !data.draft),
  getCollection('essay', ({ data }) => !data.draft),
  getCollection('projects', ({ data }) => !data.draft),
]);

const allEntries = [...notes, ...essays, ...projects];
const tags = [...collectTags(allEntries).entries()].sort((a, b) => b[1] - a[1]);
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="标签 | 6ch. · 林间笔记" description="按标签浏览内容">
  <section class="container page-shell">
    <header class="page-header">
      <p class="section-kicker">Tags</p>
      <h1>标签</h1>
      <p class="section-lead">按主题穿行 — 同一标签下的内容，往往共享相似的气味。</p>
    </header>

    <ul class="content-list tag-index">
      {
        tags.map(([tag, count]) => (
          <li>
            <a class="content-row" href={`${base}tags/${encodeURIComponent(tag)}/`}>
              <span class="content-row__marker" aria-hidden="true"></span>
              <div class="content-row__body">
                <h2 class="content-row__title">#{tag}</h2>
              </div>
              <div class="content-row__aside">
                <span class="content-row__badge">{count}</span>
                <span class="content-row__arrow" aria-hidden="true">→</span>
              </div>
            </a>
          </li>
        ))
      }
    </ul>
  </section>
</BaseLayout>
