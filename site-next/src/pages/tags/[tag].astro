---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ContentCard from '../../components/ContentCard.astro';
import { buildContentUrl, formatRecencyDate, sortByRecency } from '../../utils/content';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths = (async () => {
  const collections = ['notes', 'essay', 'projects'] as const;
  const tagMap = new Map<string, true>();

  for (const name of collections) {
    const entries = await getCollection(name, ({ data }) => !data.draft);
    for (const entry of entries) {
      for (const tag of entry.data.tags ?? []) {
        tagMap.set(tag, true);
      }
    }
  }

  return [...tagMap.keys()].map((tag) => ({
    params: { tag },
    props: { tag },
  }));
}) satisfies GetStaticPaths;

const { tag } = Astro.props;
const base = import.meta.env.BASE_URL;

const collections = ['notes', 'essay', 'projects'] as const;
const matched = sortByRecency(
  (
    await Promise.all(
      collections.map(async (name) => {
        const entries = await getCollection(name, ({ data }) => !data.draft);
        return entries
          .filter((entry) => entry.data.tags?.includes(tag))
          .map((entry) => ({ ...entry, collection: name }));
      }),
    )
  ).flat(),
);
---

<BaseLayout title={`#${tag} | 6ch. · 林间笔记`} description={`标签 ${tag} 下的全部内容`}>
  <section class="container page-shell">
    <header class="page-header">
      <p class="section-kicker">Tag</p>
      <h1>#{tag}</h1>
      <p class="section-lead">{matched.length} 篇内容</p>
    </header>

    <ul class="content-list">
      {
        matched.map((entry) => (
          <li>
            <ContentCard
              href={buildContentUrl(entry.collection, entry.id, base)}
              title={entry.data.title}
              description={entry.data.description}
              date={formatRecencyDate(entry)}
              collection={entry.collection}
            />
          </li>
        ))
      }
    </ul>
  </section>
</BaseLayout>
