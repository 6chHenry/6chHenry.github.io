---
import { getCollection, render } from 'astro:content';
import ContentLayout from '../../layouts/ContentLayout.astro';
import { buildContentUrl, normalizeSlug, sortByRecency } from '../../utils/content';
import { buildEntryCharacterTree } from '../../utils/character-tree';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths = (async () => {
  const entries = await getCollection('projects', ({ data }) => !data.draft);
  return entries.map((entry) => ({
    params: { slug: normalizeSlug(entry.id) },
    props: { entry },
  }));
}) satisfies GetStaticPaths;

const { entry } = Astro.props;
const { Content, headings } = await render(entry);
const filteredHeadings = headings.filter((h) => h.depth <= 3);
const characterTreeSvg = buildEntryCharacterTree(
  entry,
  filteredHeadings.map((h) => h.text),
);
const entries = sortByRecency(await getCollection('projects', ({ data }) => !data.draft));
const currentIndex = entries.findIndex((item) => item.id === entry.id);
const previousEntry = currentIndex >= 0 ? entries[currentIndex + 1] : undefined;
const nextEntry = currentIndex > 0 ? entries[currentIndex - 1] : undefined;
---

<ContentLayout
  title={entry.data.title}
  description={entry.data.description}
  date={entry.data.date}
  tags={entry.data.tags}
  headings={filteredHeadings.map((h) => ({ depth: h.depth, slug: h.slug, text: h.text }))}
  characterTreeSvg={characterTreeSvg}
  previous={previousEntry && {
    title: previousEntry.data.title,
    description: previousEntry.data.description,
    href: buildContentUrl('projects', previousEntry.id),
  }}
  next={nextEntry && {
    title: nextEntry.data.title,
    description: nextEntry.data.description,
    href: buildContentUrl('projects', nextEntry.id),
  }}
>
  <Content />
</ContentLayout>
