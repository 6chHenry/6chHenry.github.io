---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { buildContentUrl, formatRecencyDate, sortByRecency } from '../../utils/content';

const entries = sortByRecency(await getCollection('projects', ({ data }) => !data.draft));
const base = import.meta.env.BASE_URL;
const resolveHref = (href: string) => (href.startsWith('/') ? `${base}${href.slice(1)}` : href);
const featuredEntries = entries.filter((entry) => entry.data.featured).slice(0, 3);
const allEntries = entries.map((entry) => ({
  href: buildContentUrl('projects', entry.id, base),
  title: entry.data.title,
  description: entry.data.summary ?? entry.data.description ?? '',
  date: formatRecencyDate(entry),
  status: entry.data.status,
  techStack: entry.data.techStack ?? [],
}));
---

<BaseLayout title="作品集 | 6ch. · 林间笔记" description="6ch. 的精选项目、工程实践与项目笔记">
  <section class="container page-shell projects-page">
    <header class="projects-hero">
      <p class="section-kicker">Portfolio</p>
      <div class="projects-hero__grid">
        <h1>精选项目</h1>
        <p>
          这里收拢更像作品集的项目：有明确问题、技术路线和个人角色。下面仍保留项目笔记列表，用来记录实现过程中的推导、实验和阶段性想法。
        </p>
      </div>
    </header>

    {
      featuredEntries.length > 0 && (
        <section class="featured-projects" aria-labelledby="featured-projects-title">
          <div class="projects-section-heading">
            <h2 id="featured-projects-title">Featured Work</h2>
            <span>{featuredEntries.length} selected</span>
          </div>
          <div class="featured-projects__grid">
            {
              featuredEntries.map((entry, index) => {
                const primaryLink = entry.data.links?.[0]?.href ?? buildContentUrl('projects', entry.id, base);
                const isPaimonProject =
                  entry.data.title === 'Paimon Asks Everything' || entry.id.toLowerCase().includes('paimon-asks-everything');
                return (
                  <article class={`project-card project-card--${entry.data.accent ?? 'forest'}`}>
                    <a class="project-card__main-link" href={resolveHref(primaryLink)} aria-label={`Open ${entry.data.title}`}></a>
                    <div class={`project-card__visual${isPaimonProject ? ' project-card__visual--image' : ''}`} aria-hidden="true">
                      {isPaimonProject && (
                        <img
                          src={`${base}assets/projects/paimon-asks-everything/banner.png`}
                          alt=""
                          loading="lazy"
                          decoding="async"
                        />
                      )}
                      <span>{String(index + 1).padStart(2, '0')}</span>
                    </div>
                    <div class="project-card__body">
                      <div class="project-card__meta">
                        {entry.data.status && <span>{entry.data.status}</span>}
                        {entry.data.period && <span>{entry.data.period}</span>}
                      </div>
                      <h2>{entry.data.title}</h2>
                      <p>{entry.data.summary ?? entry.data.description}</p>
                      {entry.data.role && <p class="project-card__role">{entry.data.role}</p>}
                      {entry.data.techStack.length > 0 && (
                        <ul class="project-card__stack" aria-label={`${entry.data.title} tech stack`}>
                          {entry.data.techStack.slice(0, 5).map((tech) => <li>{tech}</li>)}
                        </ul>
                      )}
                      {entry.data.links.length > 0 && (
                        <div class="project-card__links">
                          {entry.data.links.map((link) => (
                            <a href={resolveHref(link.href)} target={link.href.startsWith('http') ? '_blank' : undefined} rel={link.href.startsWith('http') ? 'noopener' : undefined}>
                              {link.label}
                            </a>
                          ))}
                        </div>
                      )}
                    </div>
                  </article>
                );
              })
            }
          </div>
        </section>
      )
    }

    <section class="project-notes" aria-labelledby="project-notes-title">
      <div class="projects-section-heading">
        <h2 id="project-notes-title">全部项目 / 项目笔记</h2>
        <span>{allEntries.length} entries</span>
      </div>
      <ul class="project-note-list">
        {
          allEntries.map((entry) => (
            <li>
              <a class="project-note-row" href={entry.href}>
                <div>
                  <h3>{entry.title}</h3>
                  {entry.description && <p>{entry.description}</p>}
                  {entry.techStack.length > 0 && <span>{entry.techStack.slice(0, 3).join(' / ')}</span>}
                </div>
                <aside>
                  {entry.status && <strong>{entry.status}</strong>}
                  {entry.date && <time>{entry.date}</time>}
                </aside>
              </a>
            </li>
          ))
        }
      </ul>
    </section>
  </section>
</BaseLayout>

<style>
  .projects-page {
    max-width: 76rem;
  }

  .projects-hero {
    padding: 4.2rem 0 2.2rem;
    border-bottom: 1px solid color-mix(in srgb, var(--ch-accent-warm) 24%, var(--ch-border-soft));
  }

  .projects-hero__grid {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(18rem, 0.8fr);
    gap: 2rem;
    align-items: end;
  }

  .projects-hero h1 {
    margin: 0;
    font-family: var(--ch-display-font);
    font-size: clamp(3rem, 9vw, 6rem);
    line-height: 0.95;
    color: var(--ch-fg);
  }

  .projects-hero p {
    margin: 0;
    color: var(--ch-fg-muted);
    line-height: 1.8;
  }

  .featured-projects,
  .project-notes {
    padding: 2.6rem 0 0;
  }

  .projects-section-heading {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .projects-section-heading h2 {
    margin: 0;
    font-family: var(--ch-academic-font);
    font-size: 0.88rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--ch-accent);
  }

  .projects-section-heading span {
    font-family: var(--ch-mono-font);
    font-size: 0.72rem;
    color: var(--ch-accent-warm);
  }

  .featured-projects__grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }

  .project-card {
    position: relative;
    display: grid;
    min-height: 31rem;
    overflow: hidden;
    border: 1px solid color-mix(in srgb, var(--project-accent) 28%, var(--ch-border-soft));
    border-radius: 10px;
    background:
      linear-gradient(180deg, color-mix(in srgb, var(--ch-surface-solid) 78%, transparent), var(--ch-glass-bg)),
      radial-gradient(circle at 18% 8%, color-mix(in srgb, var(--project-accent) 26%, transparent), transparent 34%);
    box-shadow: 0 18px 54px color-mix(in srgb, black 10%, transparent);
    transition:
      transform var(--ch-transition),
      border-color var(--ch-transition),
      box-shadow var(--ch-transition);
  }

  .project-card--gold {
    --project-accent: var(--ch-accent-warm);
  }

  .project-card--forest {
    --project-accent: var(--ch-accent-secondary);
  }

  .project-card--ink {
    --project-accent: var(--ch-accent);
  }

  .project-card:hover {
    transform: translateY(-4px);
    border-color: color-mix(in srgb, var(--project-accent) 52%, var(--ch-border-soft));
    box-shadow: 0 24px 70px color-mix(in srgb, var(--project-accent) 16%, transparent);
  }

  .project-card__main-link {
    position: absolute;
    inset: 0;
    z-index: 1;
    border-radius: inherit;
  }

  .project-card__visual {
    position: relative;
    min-height: 10rem;
    overflow: hidden;
    border-bottom: 1px solid color-mix(in srgb, var(--project-accent) 22%, var(--ch-border-soft));
    background:
      linear-gradient(135deg, color-mix(in srgb, var(--project-accent) 26%, transparent) 0 1px, transparent 1px 24px),
      radial-gradient(circle at 72% 32%, color-mix(in srgb, var(--project-accent) 48%, transparent), transparent 34%),
      linear-gradient(135deg, color-mix(in srgb, var(--ch-fg) 10%, transparent), transparent);
    background-size: 24px 24px, auto, auto;
  }

  .project-card__visual--image {
    background: var(--ch-surface-solid);
  }

  .project-card__visual--image img {
    position: absolute;
    inset: 0;
    z-index: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .project-card__visual::before,
  .project-card__visual::after {
    position: absolute;
    content: "";
    border: 1px solid color-mix(in srgb, var(--project-accent) 42%, transparent);
  }

  .project-card__visual::before {
    inset: 2rem auto auto 1.4rem;
    width: 5.2rem;
    height: 5.2rem;
    border-radius: 999px;
  }

  .project-card__visual::after {
    right: 1.4rem;
    bottom: 1.2rem;
    width: 7rem;
    height: 3.4rem;
    border-radius: 999px 999px 10px 10px;
  }

  .project-card__visual--image::before {
    inset: 0;
    width: auto;
    height: auto;
    border: 0;
    border-radius: 0;
    background:
      linear-gradient(180deg, transparent 58%, color-mix(in srgb, var(--ch-surface-solid) 34%, transparent)),
      linear-gradient(90deg, color-mix(in srgb, var(--ch-surface-solid) 16%, transparent), transparent 38%, color-mix(in srgb, var(--ch-surface-solid) 12%, transparent));
    z-index: 1;
    pointer-events: none;
  }

  .project-card__visual--image::after {
    display: none;
  }

  .project-card__visual span {
    position: absolute;
    right: 1rem;
    top: 0.8rem;
    z-index: 1;
    font-family: var(--ch-mono-font);
    font-size: 0.78rem;
    color: var(--project-accent);
  }

  .project-card__visual--image span {
    z-index: 2;
    color: #f7ead0;
    text-shadow: 0 1px 12px color-mix(in srgb, black 58%, transparent);
  }

  .project-card__body {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    padding: 1.15rem;
  }

  .project-card__meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    margin-bottom: 0.8rem;
  }

  .project-card__meta span,
  .project-card__stack li {
    border: 1px solid color-mix(in srgb, var(--project-accent) 28%, var(--ch-border-soft));
    border-radius: 999px;
    color: color-mix(in srgb, var(--project-accent) 82%, var(--ch-fg));
    font-family: var(--ch-academic-font);
    font-size: 0.68rem;
    letter-spacing: 0.06em;
    line-height: 1.2;
  }

  .project-card__meta span {
    padding: 0.24rem 0.48rem;
    text-transform: uppercase;
  }

  .project-card h2 {
    margin: 0 0 0.75rem;
    font-family: var(--ch-display-font);
    font-size: 1.65rem;
    line-height: 1.08;
    color: var(--ch-fg);
  }

  .project-card p {
    margin: 0;
    color: var(--ch-fg-muted);
    font-size: 0.92rem;
    line-height: 1.68;
  }

  .project-card__role {
    margin-top: 0.8rem !important;
    color: var(--ch-fg) !important;
    font-family: var(--ch-academic-font);
    font-size: 0.82rem !important;
  }

  .project-card__stack {
    display: flex;
    flex-wrap: wrap;
    gap: 0.42rem;
    margin: 1rem 0 0;
    padding: 0;
    list-style: none;
  }

  .project-card__stack li {
    padding: 0.28rem 0.5rem;
  }

  .project-card__links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
    margin-top: auto;
    padding-top: 1.1rem;
  }

  .project-card__links a {
    position: relative;
    z-index: 3;
    color: var(--project-accent);
    font-family: var(--ch-academic-font);
    font-size: 0.84rem;
    font-weight: 650;
    text-decoration: none;
  }

  .project-card__links a::after {
    content: " ->";
  }

  .project-note-list {
    display: grid;
    gap: 0;
    margin: 0;
    padding: 0 0 4rem;
    list-style: none;
    border-top: 1px solid var(--ch-border-soft);
  }

  .project-note-row {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 10rem;
    gap: 1rem;
    padding: 1rem 0;
    border-bottom: 1px solid var(--ch-border-soft);
    color: inherit;
    text-decoration: none;
  }

  .project-note-row h3 {
    margin: 0;
    color: var(--ch-fg);
    font-family: var(--ch-display-font);
    font-size: 1.12rem;
  }

  .project-note-row p {
    margin: 0.22rem 0 0;
    color: var(--ch-fg-muted);
    font-size: 0.9rem;
    line-height: 1.6;
  }

  .project-note-row span,
  .project-note-row time,
  .project-note-row strong {
    font-family: var(--ch-academic-font);
    font-size: 0.76rem;
  }

  .project-note-row span {
    display: inline-block;
    margin-top: 0.45rem;
    color: var(--ch-accent-warm);
  }

  .project-note-row aside {
    display: grid;
    align-content: start;
    justify-items: end;
    gap: 0.25rem;
    color: var(--ch-fg-muted);
  }

  .project-note-row strong {
    color: var(--ch-accent);
    font-weight: 600;
  }

  @media (max-width: 980px) {
    .projects-hero__grid,
    .featured-projects__grid {
      grid-template-columns: 1fr;
    }

    .project-card {
      min-height: auto;
    }
  }

  @media (max-width: 640px) {
    .projects-hero {
      padding-top: 3rem;
    }

    .project-note-row {
      grid-template-columns: 1fr;
    }

    .project-note-row aside {
      justify-items: start;
    }
  }
</style>
