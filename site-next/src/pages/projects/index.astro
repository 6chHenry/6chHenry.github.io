---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ContentCard from '../../components/ContentCard.astro';
import { buildContentUrl, formatRecencyDate, sortByRecency } from '../../utils/content';

const entries = sortByRecency(await getCollection('projects', ({ data }) => !data.draft));
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="项目 | 6ch. · 林间笔记" description="6ch. 的项目记录">
  <section class="container page-shell">
    <header class="page-header">
      <p class="section-kicker">Projects</p>
      <h1>项目</h1>
      <p class="section-lead">实验与工程的记录 — 从种子到成形的过程。</p>
    </header>

    <ul class="content-list">
      {
        entries.map((entry) => (
          <li>
            <ContentCard
              href={buildContentUrl('projects', entry.id, base)}
              title={entry.data.title}
              description={entry.data.description ?? ''}
              date={formatRecencyDate(entry)}
              collection="projects"
            />
          </li>
        ))
      }
    </ul>
  </section>
</BaseLayout>
