---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import GalleryImage from '../components/GalleryImage.astro';
import ForestIcon from '../components/ForestIcon.astro';
import ForestMap from '../components/ForestMap.astro';
import { buildContentUrl, formatRecencyDate, sortByRecency } from '../utils/content';
import { buildForestMapStops } from '../utils/forest-map';

const base = import.meta.env.BASE_URL;
const heroPhotos = [
  { src: `${base}assets/gallery/photography/kyoto.assets/kifune_shrine.jpg`, alt: 'Kyoto shrine path' },
  { src: `${base}assets/gallery/photography/kobe.assets/kobe_sunset.jpg`, alt: 'Kobe sunset' },
  { src: `${base}assets/gallery/photography/geermu.assets/railway_sunset.jpg`, alt: 'Geermu railway sunset' },
  { src: `${base}assets/gallery/photography/hong-kong.assets/Victoria_Peak.JPG`, alt: 'Hong Kong skyline' },
];

const [notes, essays, projects] = await Promise.all([
  getCollection('notes', ({ data }) => !data.draft),
  getCollection('essay', ({ data }) => !data.draft),
  getCollection('projects', ({ data }) => !data.draft),
]);

const allContent = [...notes, ...essays, ...projects];
const forestStops = buildForestMapStops(allContent, base);
const collectionLabels: Record<string, string> = {
  notes: '笔记',
  essay: '杂谈',
  projects: '作品',
};

const recent = sortByRecency(allContent)
  .filter((entry) => entry.data.updatedAt || entry.data.date)
  .slice(0, 8)
  .map((entry) => ({
    href: buildContentUrl(entry.collection, entry.id, base),
    title: entry.data.title,
    date: formatRecencyDate(entry),
    collection: entry.collection,
    collectionLabel: collectionLabels[entry.collection] ?? '记录',
  }));

const latestNote = sortByRecency(notes)[0];
const latestEssay = sortByRecency(essays)[0];
const latestProject = sortByRecency(projects)[0];

const practices = [
  {
    index: '01',
    tone: 'learn',
    icon: 'book' as const,
    eyebrow: 'Learn · 学习',
    title: '把理解留下来',
    description: '不只收藏知识，而是把复杂概念拆开、重组，直到它能被下一次思考继续使用。',
    href: `${base}notes/`,
    count: `${notes.length} 篇笔记`,
    latest: latestNote && {
      href: buildContentUrl(latestNote.collection, latestNote.id, base),
      title: latestNote.data.title,
      date: formatRecencyDate(latestNote),
    },
  },
  {
    index: '02',
    tone: 'make',
    icon: 'code' as const,
    eyebrow: 'Make · 创作',
    title: '把想法做成东西',
    description: '让研究、代码与界面落在同一个作品里；原型是我思考时最诚实的一版草稿。',
    href: `${base}projects/`,
    count: `${projects.length} 个项目`,
    latest: latestProject && {
      href: buildContentUrl(latestProject.collection, latestProject.id, base),
      title: latestProject.data.title,
      date: formatRecencyDate(latestProject),
    },
  },
  {
    index: '03',
    tone: 'wander',
    icon: 'pen' as const,
    eyebrow: 'Wander · 漫游',
    title: '去别处重新看世界',
    description: '旅行、电影和日常观察，提醒我在技术之外，继续感受具体的人与真实的生活。',
    href: `${base}essay/`,
    count: `${essays.length} 则杂谈`,
    latest: latestEssay && {
      href: buildContentUrl(latestEssay.collection, latestEssay.id, base),
      title: latestEssay.data.title,
      date: formatRecencyDate(latestEssay),
    },
  },
];
---

<BaseLayout title="6ch. · 林间笔记" description="在森林般的宽阔里，记录 AI、视觉与思考的片段" bodyClass="page-home">
  <section class="home-hero">
    <div class="home-sky" aria-hidden="true"></div>
    <div class="home-hills" aria-hidden="true"></div>
    <div class="home-treeline" aria-hidden="true"></div>
    <div class="home-mist" aria-hidden="true"></div>
    <div class="home-light" aria-hidden="true"></div>
    <div class="home-grain" aria-hidden="true"></div>
    <div class="home-photo-collage" aria-hidden="true">
      {
        heroPhotos.map((photo, index) => (
          <figure class={`home-photo home-photo--${index + 1}`}>
            <GalleryImage
              src={photo.src}
              alt={photo.alt}
              sizes="(max-width: 720px) 72vw, 28rem"
              loading={index === 0 ? 'eager' : 'lazy'}
              fetchpriority={index === 0 ? 'high' : 'auto'}
            />
          </figure>
        ))
      }
    </div>

    <div class="home-inner">
      <div class="home-avatar-wrap">
        <img class="home-avatar" src={`${base}img/avatar1.jpg`} alt="6ch." width="124" height="124" />
      </div>
      <p class="home-eyebrow">Forest Journal · Personal Archive</p>
      <h1 class="home-title"><span>6ch.</span></h1>
      <p class="home-tagline">AI / Embodied Intelligence / Travel Notes / Self-directed Inquiry</p>
      <p class="home-subtitle">
        上海交通大学 · 人工智能学院<br />
        把学习、工程和旅行记忆整理成一片可以反复进入的林地。
      </p>
    </div>
  </section>

  <section class="home-wayfinder" aria-labelledby="home-wayfinder-title">
    <div class="home-wayfinder__shell">
      <header class="home-wayfinder__header">
        <p class="home-wayfinder__kicker">Trailhead · 林地入口</p>
        <div>
          <h2 id="home-wayfinder-title">选一条路，往林子里走</h2>
          <p>这不是一张站点地图，而是四条进入我的路径。</p>
        </div>
      </header>

      <nav class="home-wayfinder__grid" aria-label="探索入口">
        <a class="home-path" href={`${base}about/`}>
          <span class="home-path__topline">
            <span class="home-path__index">01</span>
            <span class="home-path__icon"><ForestIcon name="leaf" /></span>
          </span>
          <span class="home-path__title">认识我</span>
          <span class="home-path__description">我的坐标、兴趣与正在寻找的问题</span>
          <span class="home-path__arrow" aria-hidden="true">→</span>
        </a>
        <a class="home-path" href={`${base}notes/`}>
          <span class="home-path__topline">
            <span class="home-path__index">02</span>
            <span class="home-path__icon"><ForestIcon name="book" /></span>
          </span>
          <span class="home-path__title">翻阅笔记</span>
          <span class="home-path__description">AI、数学与工程学习留下的知识年轮</span>
          <span class="home-path__arrow" aria-hidden="true">→</span>
        </a>
        <a class="home-path" href={`${base}essay/`}>
          <span class="home-path__topline">
            <span class="home-path__index">03</span>
            <span class="home-path__icon"><ForestIcon name="pen" /></span>
          </span>
          <span class="home-path__title">读些杂谈</span>
          <span class="home-path__description">旅行、电影与生活片段的私人标本</span>
          <span class="home-path__arrow" aria-hidden="true">→</span>
        </a>
        <a class="home-path" href={`${base}projects/`}>
          <span class="home-path__topline">
            <span class="home-path__index">04</span>
            <span class="home-path__icon"><ForestIcon name="code" /></span>
          </span>
          <span class="home-path__title">看看作品</span>
          <span class="home-path__description">从模型到界面，把想法做成可体验的作品</span>
          <span class="home-path__arrow" aria-hidden="true">→</span>
        </a>
      </nav>

      <footer class="home-wayfinder__footer">
        <p><span>Archive note</span> · 内容仍在生长，路径会随我一起改变。</p>
        <button type="button" class="home-wayfinder__stats" id="home-stats-toggle" aria-expanded="false" aria-controls="statistics">
          <ForestIcon name="tree" />
          <span>查看这片林的年轮</span>
        </button>
      </footer>

      <div id="statistics" class="home-stats" role="region" aria-label="站点统计">
        <div class="home-stats__inner">
          <ul>
            <li>从第一颗种子到现在 <span id="web-time"></span></li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section class="container home-section">
    <p class="section-kicker">Practice</p>
    <h2 class="section-title">我反复做的三件事</h2>
    <p class="section-lead">这个网站大致由三种动作长出来：弄懂一件事，做出一个东西，再去别处看看。</p>

    <div class="practice-grid">
      {
        practices.map((item) => (
          <article class="practice-card" data-practice={item.tone} data-index={item.index}>
            <div class="practice-card__topline">
              <span class="practice-card__index">{item.index}</span>
              <span class="practice-card__icon">
              <ForestIcon name={item.icon} />
              </span>
            </div>
            <p class="practice-card__eyebrow">{item.eyebrow}</p>
            <h3>{item.title}</h3>
            <p class="practice-card__description">{item.description}</p>

            {
              item.latest && (
                <div class="practice-card__latest">
                  <span>
                    最近留下
                    {item.latest.date && <time>{item.latest.date}</time>}
                  </span>
                  <a href={item.latest.href}>
                    {item.latest.title}
                    <span aria-hidden="true">↗</span>
                  </a>
                </div>
              )
            }

            <footer class="practice-card__footer">
              <span>{item.count}</span>
              <a href={item.href}>沿这条路继续 <span aria-hidden="true">→</span></a>
            </footer>
          </article>
        ))
      }
    </div>
  </section>

  {
    recent.length > 0 && (
      <section class="container recent-section">
        <header class="recent-section__header">
          <div>
            <p class="section-kicker">Recent traces</p>
            <h2 class="section-title">最近留下的痕迹</h2>
            <p class="section-lead">按时间拾起最近的八次更新，看这片林正在往哪里生长。</p>
          </div>
          <p class="recent-section__edition"><span>Latest 08</span> · chronological field notes</p>
        </header>
        <ul class="content-list recent-list">
          {
            recent.map((item, index) => (
              <li>
                <a class="content-row recent-row" href={item.href}>
                  <span class="recent-row__index" aria-hidden="true">{String(index + 1).padStart(2, '0')}</span>
                  <div class="content-row__body">
                    <div class="recent-row__meta">
                      <span class={`recent-row__type recent-row__type--${item.collection}`}>{item.collectionLabel}</span>
                      {item.date && <time class="content-row__date">{item.date}</time>}
                    </div>
                    <h2 class="content-row__title">{item.title}</h2>
                  </div>
                  <span class="content-row__arrow" aria-hidden="true">→</span>
                </a>
              </li>
            ))
          }
        </ul>
      </section>
    )
  }

  {
    forestStops.totalCount > 0 && <ForestMap stops={forestStops} />
  }
</BaseLayout>

<script>
  import { initHomeStats } from '../scripts/home';
  initHomeStats();
</script>
