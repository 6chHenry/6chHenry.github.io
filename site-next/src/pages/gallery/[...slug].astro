---
import { getCollection, getEntry, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GalleryLightbox from '../../components/GalleryLightbox.astro';
import GalleryImage from '../../components/GalleryImage.astro';
import { formatDate, normalizeSlug } from '../../utils/content';
import { GALLERY_CITY_ORDER } from '../../data/gallery-order';
import { resolveGalleryImages } from '../../utils/gallery-images';

function sortGalleryEntries<T extends { id: string; data: { updatedAt?: Date; date?: Date } }>(entries: T[]): T[] {
  const grouped = new Map<string, number>();
  GALLERY_CITY_ORDER.forEach((slug, i) => grouped.set(slug, i));

  const groupedEntries: T[] = [];
  const otherEntries: T[] = [];

  for (const e of entries) {
    if (grouped.has(e.id)) {
      groupedEntries.push(e);
    } else {
      otherEntries.push(e);
    }
  }

  groupedEntries.sort((a, b) => (grouped.get(a.id) ?? 99) - (grouped.get(b.id) ?? 99));
  otherEntries.sort((a, b) => (b.data.date?.getTime() ?? 0) - (a.data.date?.getTime() ?? 0));

  return [...groupedEntries, ...otherEntries];
}

export async function getStaticPaths() {
  const entries = await getCollection('gallery', ({ data }) => !data.draft);
  return entries.map((entry) => ({
    params: { slug: normalizeSlug(entry.id) },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const { data } = entry;
const allImages = [data.cover, ...data.images];
const allImageAssets = resolveGalleryImages(allImages);
const allImageDescs = [data.coverDesc ?? '', ...(data.imageDescs ?? [])];

const allEntries = sortGalleryEntries(
  await getCollection('gallery', ({ data }) => !data.draft),
);
const idx = allEntries.findIndex((e) => e.id === entry.id);
const previous = idx > 0 ? allEntries[idx - 1] : null;
const next = idx < allEntries.length - 1 ? allEntries[idx + 1] : null;

const base = import.meta.env.BASE_URL;

const categoryLabels: Record<string, string> = {
  illustration: '插画',
  photography: '摄影',
  design: '设计',
  'ui-ux': 'UI/UX',
  other: '其他',
};
---

<BaseLayout
  title={`${data.title} | 画廊 | 6ch.`}
  description={data.description}
>
  <article class="container page-shell">
    <header class="page-header">
      <p class="section-kicker">Gallery</p>
      <h1>{data.title}</h1>
      {data.description && <p class="section-lead">{data.description}</p>}
    </header>

    <div class="gallery-detail-meta">
      <span class="gallery-detail-category">
        {categoryLabels[data.category] ?? data.category}
      </span>
      {data.date && (
        <time class="gallery-detail-date" datetime={data.date.toISOString()}>
          {formatDate(data.date)}
        </time>
      )}
      {
        data.tags.length > 0 && (
          <div class="gallery-detail-tags">
            {data.tags.map((tag) => (
              <a href={`${base}tags/${encodeURIComponent(tag)}/`}>#{tag}</a>
            ))}
          </div>
        )
      }
      <a
        class="gallery-original-download"
        id="gallery-original-download"
        href={allImageAssets[0].original}
        download
      >
        下载当前原图
      </a>
    </div>

    <div class="gallery-detail-hero">
      <GalleryImage
        id="gallery-hero"
        asset={allImageAssets[0]}
        alt={data.title}
        sizes="(max-width: 900px) 100vw, 76rem"
        loading="eager"
        fetchpriority="high"
        data-images={JSON.stringify(allImageAssets)}
        data-descs={JSON.stringify(allImageDescs)}
      />
    </div>
    <p class="gallery-detail-image-desc" id="gallery-image-desc"></p>

    {
      entry.body && (
        <div class="prose card card--elevated" style="padding: 2rem 2.15rem 2.5rem;" data-pagefind-body>
          <Content />
        </div>
      )
    }

    {
      data.images.length > 0 && (
        <div class="gallery-detail-grid">
          <button
            type="button"
            data-thumb={JSON.stringify(allImageAssets[0])}
            data-index={0}
            class="is-active"
          >
            <GalleryImage
              asset={allImageAssets[0]}
              alt={data.title}
              sizes="(max-width: 640px) 50vw, 16rem"
              loading="lazy"
            />
          </button>
          {allImageAssets.slice(1).map((asset, i) => (
            <button
              type="button"
              data-thumb={JSON.stringify(asset)}
              data-index={i + 1}
            >
              <GalleryImage
                asset={asset}
                alt={`${data.title} - ${i + 2}`}
                sizes="(max-width: 640px) 50vw, 16rem"
                loading="lazy"
              />
            </button>
          ))}
        </div>
      )
    }

    {
      (previous || next) && (
        <nav class="article-nav" aria-label="作品导航">
          {
            previous ? (
              <a class="article-nav__link article-nav__link--prev" href={`${base}gallery/${normalizeSlug(previous.id)}/`}>
                <span class="article-nav__eyebrow">上一件</span>
                <strong>{previous.data.title}</strong>
                {previous.data.description && <span>{previous.data.description}</span>}
              </a>
            ) : (
              <span class="article-nav__spacer" aria-hidden="true"></span>
            )
          }
          {
            next ? (
              <a class="article-nav__link article-nav__link--next" href={`${base}gallery/${normalizeSlug(next.id)}/`}>
                <span class="article-nav__eyebrow">下一件</span>
                <strong>{next.data.title}</strong>
                {next.data.description && <span>{next.data.description}</span>}
              </a>
            ) : (
              <span class="article-nav__spacer" aria-hidden="true"></span>
            )
          }
        </nav>
      )
    }
  </article>

  <GalleryLightbox />
</BaseLayout>

<script>
  import { initGalleryLightbox } from '../../scripts/gallery';

  initGalleryLightbox();

  const hero = document.getElementById('gallery-hero') as HTMLImageElement | null;
  const grid = document.querySelector<HTMLElement>('.gallery-detail-grid');
  const imageDescEl = document.getElementById('gallery-image-desc');
  const downloadLink = document.getElementById('gallery-original-download') as HTMLAnchorElement | null;

  if (hero && grid) {
    let currentSrc = hero.getAttribute('src') ?? hero.src;
    const heroSource = hero.closest('picture')?.querySelector<HTMLSourceElement>('source');
    let descs: string[] = [];
    try { descs = JSON.parse(hero.dataset.descs || '[]'); } catch { /* ignore */ }

    grid.addEventListener('click', (event) => {
      const btn = (event.target as HTMLElement).closest<HTMLButtonElement>('[data-thumb]');
      if (!btn) return;

      const rawAsset = btn.dataset.thumb;
      const newIndex = parseInt(btn.dataset.index || '0', 10);
      if (!rawAsset) return;
      let asset: { src: string; webpSrcset: string; width?: number; height?: number; original: string };
      try { asset = JSON.parse(rawAsset); } catch { return; }
      if (asset.src === currentSrc) return;

      currentSrc = asset.src;
      hero.classList.add('is-swapping');

      setTimeout(() => {
        if (heroSource) {
          heroSource.srcset = asset.webpSrcset;
          heroSource.sizes = '(max-width: 900px) 100vw, 76rem';
        }
        hero.src = asset.src;
        if (asset.width) hero.width = asset.width;
        if (asset.height) hero.height = asset.height;
        hero.onload = () => hero.classList.remove('is-swapping');
        hero.onerror = () => hero.classList.remove('is-swapping');
      }, 180);

      if (downloadLink) downloadLink.href = asset.original;
      if (imageDescEl) {
        imageDescEl.textContent = descs[newIndex] ?? '';
      }

      for (const b of grid.querySelectorAll('button')) {
        b.classList.toggle('is-active', b === btn);
      }
    });
  }
</script>

<style>
  .gallery-original-download {
    margin-left: auto;
    padding: 0.42rem 0.75rem;
    border: 1px solid var(--ch-border-soft);
    border-radius: 999px;
    color: var(--ch-accent);
    font-family: var(--ch-academic-font);
    font-size: 0.78rem;
    font-weight: 700;
    text-decoration: none;
  }

  .gallery-original-download:hover,
  .gallery-original-download:focus-visible {
    border-color: var(--ch-accent-secondary);
    background: var(--ch-accent-dim);
  }
</style>
