---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GalleryCard from '../../components/GalleryCard.astro';
import GalleryImage from '../../components/GalleryImage.astro';
import GalleryLightbox from '../../components/GalleryLightbox.astro';
import { buildContentUrl, formatDate, sortByRecency } from '../../utils/content';

const hiddenCities = new Set(['osaka', 'kyoto', 'nara', 'uji', 'kobe', 'himeji', 'guangzhou', 'hong-kong', 'macau', 'wuhan', 'lushan', 'nanchang']);
const base = import.meta.env.BASE_URL;
const entries = sortByRecency(
  await getCollection('gallery', ({ data }) => !data.draft),
).filter((entry) => {
  const parts = entry.id.split('/');
  const slug = (parts[parts.length - 1] || '').replace(/\.md$/, '');
  if (parts[0] === 'photography' && hiddenCities.has(slug)) return false;
  return true;
});

const getEntrySlug = (id: string) => {
  const parts = id.split('/');
  return (parts[parts.length - 1] || '').replace(/\.md$/, '');
};

const entryBySlug = new Map(entries.map((entry) => [getEntrySlug(entry.id), entry]));
const countImages = (slug: string) => {
  const entry = entryBySlug.get(slug);
  return entry ? entry.data.images.length + 1 : 0;
};

const categories = ['illustration', 'photography', 'design', 'ui-ux', 'other'] as const;
const categoryLabels: Record<string, string> = {
  illustration: '插画',
  photography: '摄影',
  design: '设计',
  'ui-ux': 'UI/UX',
  other: '其他',
};
const categoryCounts = Object.fromEntries(categories.map((cat) => [cat, 0])) as Record<string, number>;
for (const entry of entries) {
  categoryCounts[entry.data.category] = (categoryCounts[entry.data.category] ?? 0) + 1;
}

const timeline = [
  {
    date: '1.20 — 1.23',
    title: '鄂赣行记',
    subtitle: '武汉 · 庐山 · 南昌',
    cover: '/assets/gallery/photography/wuhan.assets/yellow_crane_tower.jpg',
    href: `${base}gallery/hubei-jiangxi/`,
    gallerySlug: 'hubei-jiangxi',
    color: '#4a90d9',
    month: 1,
    cities: 3,
    side: 'above' as const,
  },
  {
    date: '2.25',
    title: '格尔木',
    subtitle: '察尔汗盐湖 · 昆仑山',
    cover: '/assets/gallery/photography/geermu.assets/qarhan_saltlake_1.jpg',
    href: `${base}gallery/photography/geermu/`,
    gallerySlug: 'geermu',
    color: '#2d7a5f',
    month: 2,
    cities: 1,
    side: 'below' as const,
  },
  {
    date: '4.4 — 4.8',
    title: '粤港澳三城游',
    subtitle: '广州 · 澳门 · 香港',
    cover: '/assets/gallery/photography/guangzhou.assets/Yat-sen_Mausoleum_front.JPG',
    href: `${base}gallery/bay-area/`,
    gallerySlug: 'greater-bay-area',
    color: '#1a5276',
    month: 4,
    cities: 3,
    side: 'above' as const,
  },
  {
    date: '5.3 — 5.6',
    title: '関西旅路',
    subtitle: '大阪 · 奈良 · 宇治 · 京都 · 神户 · 姬路',
    cover: '/assets/gallery/photography/osaka.assets/glico.jpg',
    href: `${base}gallery/japan/`,
    gallerySlug: 'japan',
    color: '#5a9e4b',
    month: 5,
    cities: 6,
    side: 'below' as const,
  },
].map((trip) => ({
  ...trip,
  images: countImages(trip.gallerySlug),
}));
---

<BaseLayout
  title="画廊 | 6ch. · 林间笔记"
  description="6ch. 的作品集与视觉创作"
>
  <section class="container page-shell">
    <header class="page-header">
      <p class="section-kicker">Gallery</p>
      <h1>画廊</h1>
      <p class="section-lead">
        视觉创作的陈列室 — 插画、摄影、设计，每一幅都是林间的一扇窗。
      </p>
    </header>

    <!-- 2026 Journey Timeline -->
    <div class="trip-timeline">
      <h2 class="trip-timeline__heading">2026 · 旅程时间线</h2>

      <div class="trip-timeline__axis">
        <!-- Month labels -->
        <div class="trip-timeline__months">
          {['1月', '2月', '3月', '4月', '5月', '6月'].map((m) => (
            <span class="trip-timeline__month">{m}</span>
          ))}
        </div>

        <!-- Axis line with ticks -->
        <div class="trip-timeline__track">
          {[1, 2, 3, 4, 5, 6].map((m) => (
            <span class="trip-timeline__tick" style={`left: ${(m - 0.5) * (100/6)}%`}></span>
          ))}

          <!-- Trip nodes -->
          {
            timeline.map((trip, i) => (
              <a
                href={trip.href}
                class:list={[
                  'trip-timeline__node',
                  `trip-timeline__node--${trip.side}`,
                ]}
                data-trip-target={trip.gallerySlug}
                aria-label={`打开 ${trip.title}，${trip.cities} 城，${trip.images} 张照片`}
                style={`--trip-color: ${trip.color}; --trip-month: ${trip.month}; --trip-left: ${(trip.month - 0.5) * (100 / 6)}%`}
              >
                <div class="trip-timeline__stem" aria-hidden="true"></div>
                <div class="trip-timeline__dot" aria-hidden="true"></div>
                <div class="trip-timeline__card">
                  <div class="trip-timeline__card-img">
                    <GalleryImage
                      src={trip.cover}
                      alt={trip.title}
                      sizes="(max-width: 860px) calc(100vw - 3rem), 11rem"
                      loading={i === 0 ? 'eager' : 'lazy'}
                      fetchpriority={i === 0 ? 'high' : 'auto'}
                    />
                    <div class="trip-timeline__card-accent" style={`background: ${trip.color}`}></div>
                  </div>
                  <div class="trip-timeline__card-body">
                    <time class="trip-timeline__date">{trip.date}</time>
                    <strong class="trip-timeline__title">{trip.title}</strong>
                    <span class="trip-timeline__sub">{trip.subtitle}</span>
                    <span class="trip-timeline__meta">
                      <span>{trip.cities} 城</span>
                      <span>{trip.images} 张</span>
                    </span>
                  </div>
                </div>
              </a>
            ))
          }

          <!-- 未完待续 marker -->
          <div class="trip-timeline__node trip-timeline__node--future" style="--trip-month: 6; --trip-left: 91.6667%">
            <div class="trip-timeline__dot trip-timeline__dot--ghost" aria-hidden="true"></div>
            <div class="trip-timeline__future-label">
              <span class="trip-timeline__future-icon">✦</span>
              未完待续
            </div>
          </div>
        </div>
      </div>
    </div>

    {
      entries.length > 0 ? (
        <>
          <div class="gallery-filters" role="group" aria-label="按分类筛选">
            <button
              type="button"
              class="gallery-filter"
              data-category=""
              aria-pressed="true"
            >
              <span>全部</span>
              <span class="gallery-filter__count">{entries.length}</span>
            </button>
            {
              categories.map((cat) => (
                <button
                  type="button"
                  class="gallery-filter"
                  data-category={cat}
                  aria-pressed="false"
                >
                  <span>{categoryLabels[cat]}</span>
                  <span class="gallery-filter__count">{categoryCounts[cat] ?? 0}</span>
                </button>
              ))
            }
          </div>

          <div class="gallery-grid">
            {
              entries.map((entry, i) => {
                const allImages = [entry.data.cover, ...entry.data.images];
                const slug = getEntrySlug(entry.id);
                return (
                  <GalleryCard
                    href={buildContentUrl('gallery', entry.id, base)}
                    cover={entry.data.cover}
                    title={entry.data.title}
                    description={entry.data.description}
                    category={entry.data.category}
                    images={allImages}
                    imageDescs={entry.data.imageDescs}
                    date={entry.data.date ? formatDate(entry.data.date) : undefined}
                    index={i}
                    slug={slug}
                  />
                );
              })
            }
          </div>

          <GalleryLightbox />
        </>
      ) : (
        <div class="gallery-empty card card--elevated">
          <p>
            画廊还在筹备中，作品即将上架。<br />
            林间正在生长，请稍后再来。
          </p>
        </div>
      )
    }
  </section>
</BaseLayout>

<script>
  import { initGalleryFilters, initGalleryLightbox, initGalleryTimelineHighlights } from '../../scripts/gallery';
  initGalleryFilters();
  initGalleryLightbox();
  initGalleryTimelineHighlights();
</script>

<style>
  /* ---- Trip Timeline ---- */
  .trip-timeline {
    margin: 2.5rem 0 3.5rem;
  }

  .trip-timeline__heading {
    font-family: var(--ch-display-font);
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    color: var(--ch-fg-muted);
    margin: 0 0 2rem;
    text-align: center;
  }

  /* Month labels */
  .trip-timeline__months {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    margin-bottom: 0.4rem;
  }

  .trip-timeline__month {
    text-align: center;
    font-family: var(--ch-mono-font);
    font-size: 0.62rem;
    letter-spacing: 0.1em;
    color: var(--ch-fg-muted);
    opacity: 0.45;
  }

  /* Track: 6-col grid. Axis line runs through absolute vertical center.
     Each node spans its column, dots are anchored at center. */
  .trip-timeline__track {
    position: relative;
    min-height: 24rem;
    --trip-card-gap: 1.35rem;
  }

  /* Horizontal axis line */
  .trip-timeline__track::before {
    content: '';
    position: absolute;
    top: 50%;
    left: 0;
    right: 0;
    height: 1px;
    background: var(--ch-border);
    transform: translateY(-0.5px);
  }

  /* Tick marks at each month position */
  .trip-timeline__tick {
    position: absolute;
    top: 50%;
    width: 1px;
    height: 8px;
    background: var(--ch-border);
    transform: translate(-50%, -50%);
    pointer-events: none;
  }

  .trip-timeline__node {
    position: absolute;
    top: 0;
    bottom: 0;
    left: var(--trip-left);
    width: min(11rem, calc(100% / 6 - 0.65rem));
    align-items: center;
    text-decoration: none;
    color: inherit;
    z-index: 1;
    transform: translateX(-50%);
    transition: transform 0.3s ease;
  }

  .trip-timeline__node:hover,
  .trip-timeline__node:focus-visible,
  .trip-timeline__node.is-linked {
    transform: translate(-50%, -2px);
  }

  .trip-timeline__node--below:hover,
  .trip-timeline__node--below:focus-visible,
  .trip-timeline__node--below.is-linked {
    transform: translate(-50%, 2px);
  }

  .trip-timeline__node:focus-visible {
    outline: none;
  }

  .trip-timeline__node:focus-visible .trip-timeline__card {
    box-shadow:
      0 0 0 2px color-mix(in srgb, var(--trip-color) 42%, transparent),
      0 6px 24px color-mix(in srgb, var(--trip-color) 18%, transparent);
  }

  /* Dot: absolute at axis center */
  .trip-timeline__dot {
    position: absolute;
    left: 50%;
    top: 50%;
    width: 0.6rem;
    height: 0.6rem;
    border-radius: 50%;
    background: var(--trip-color);
    border: 2px solid var(--ch-surface-solid);
    box-shadow: 0 0 0 2px var(--trip-color);
    transform: translate(-50%, -50%);
    z-index: 2;
  }

  /* Stem: absolute, from dot to card */
  .trip-timeline__stem {
    position: absolute;
    left: 50%;
    width: 1px;
    background: var(--trip-color);
    opacity: 0.35;
    z-index: 0;
  }

  .trip-timeline__node--above .trip-timeline__stem {
    top: calc(50% - var(--trip-card-gap));
    height: var(--trip-card-gap);
    transform: translateY(-100%);
  }

  .trip-timeline__node--below .trip-timeline__stem {
    top: 50%;
    height: var(--trip-card-gap);
  }

  .trip-timeline__node--above .trip-timeline__card {
    bottom: calc(50% + var(--trip-card-gap));
  }

  .trip-timeline__node--below .trip-timeline__card {
    top: calc(50% + var(--trip-card-gap));
  }

  /* Trip card */
  .trip-timeline__card {
    position: absolute;
    left: 50%;
    z-index: 1;
    width: 100%;
    background: var(--ch-glass-bg);
    border: 1px solid var(--ch-glass-border);
    border-radius: var(--ch-radius);
    overflow: hidden;
    backdrop-filter: blur(var(--ch-glass-blur));
    transition:
      border-color 0.3s ease,
      box-shadow 0.3s ease;
    transform: translateX(-50%);
  }

  .trip-timeline__node:hover .trip-timeline__card,
  .trip-timeline__node.is-linked .trip-timeline__card {
    border-color: var(--trip-color);
    box-shadow: 0 6px 24px color-mix(in srgb, var(--trip-color) 18%, transparent);
  }

  .trip-timeline__card-img {
    aspect-ratio: 16 / 9;
    overflow: hidden;
    position: relative;
  }

  .trip-timeline__card-img img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.45s ease;
  }

  .trip-timeline__node:hover .trip-timeline__card-img img,
  .trip-timeline__node.is-linked .trip-timeline__card-img img {
    transform: scale(1.06);
  }

  .trip-timeline__card-accent {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 2px;
  }

  .trip-timeline__card-body {
    padding: 0.6rem 0.75rem;
  }

  .trip-timeline__date {
    display: block;
    font-family: var(--ch-mono-font);
    font-size: 0.58rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--trip-color);
    font-weight: 500;
    margin-bottom: 0.15rem;
  }

  .trip-timeline__title {
    display: block;
    font-family: var(--ch-display-font);
    font-size: 0.9rem;
    font-weight: 600;
    letter-spacing: 0.03em;
    margin-bottom: 0.12rem;
  }

  .trip-timeline__sub {
    display: block;
    font-size: 0.64rem;
    color: var(--ch-fg-muted);
    line-height: 1.35;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .trip-timeline__meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    margin-top: 0.5rem;
    font-family: var(--ch-mono-font);
    font-size: 0.56rem;
    color: var(--ch-fg-muted);
  }

  .trip-timeline__meta span {
    display: inline-flex;
    align-items: center;
    min-height: 1.25rem;
    padding: 0 0.4rem;
    border-radius: 999px;
    background: color-mix(in srgb, var(--trip-color) 9%, var(--ch-surface-solid));
    border: 1px solid color-mix(in srgb, var(--trip-color) 16%, var(--ch-glass-border));
  }

  /* ---- 未完待续 ---- */
  .trip-timeline__node--future {
    position: absolute;
    top: 0;
    bottom: 0;
    left: var(--trip-left);
    width: min(11rem, calc(100% / 6 - 0.65rem));
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    color: inherit;
    z-index: 1;
    transform: translateX(-50%);
  }

  .trip-timeline__dot--ghost {
    position: absolute;
    left: 50%;
    top: 50%;
    width: 0.6rem;
    height: 0.6rem;
    border-radius: 50%;
    background: transparent;
    border: 2px dashed var(--ch-border);
    transform: translate(-50%, -50%);
    z-index: 2;
  }

  .trip-timeline__future-label {
    position: relative;
    z-index: 1;
    margin-top: 1.2rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.15rem;
    font-family: var(--ch-display-font);
    font-size: 0.78rem;
    color: var(--ch-fg-muted);
    letter-spacing: 0.06em;
    opacity: 0.7;
  }

  .trip-timeline__future-icon {
    font-size: 0.85rem;
    opacity: 0.5;
  }

  @media (max-width: 860px) {
    .trip-timeline__track {
      display: flex;
      flex-direction: column;
      min-height: auto;
      padding: 0.5rem 0;
    }

    .trip-timeline__track::before {
      left: 0.55rem;
      right: auto;
      top: 0.5rem;
      bottom: 0.5rem;
      width: 1px;
      height: auto;
      transform: none;
    }

    .trip-timeline__months {
      display: none;
    }

    .trip-timeline__node,
    .trip-timeline__node--above,
    .trip-timeline__node--below {
      position: relative;
      top: auto;
      bottom: auto;
      left: auto;
      width: 100%;
      display: flex;
      flex-direction: row;
      align-items: flex-start;
      justify-content: flex-start;
      gap: 0.75rem;
      padding: 0.5rem 0 0.5rem 1.5rem;
      transform: none;
    }

    .trip-timeline__node:hover,
    .trip-timeline__node:focus-visible,
    .trip-timeline__node.is-linked,
    .trip-timeline__node--below:hover,
    .trip-timeline__node--below:focus-visible,
    .trip-timeline__node--below.is-linked {
      transform: none;
    }

    .trip-timeline__dot,
    .trip-timeline__node--above .trip-timeline__dot,
    .trip-timeline__node--below .trip-timeline__dot {
      position: absolute;
      left: 0.25rem;
      top: 1rem;
      transform: none;
    }

    .trip-timeline__stem {
      display: none;
    }

    .trip-timeline__card {
      position: relative;
      top: auto;
      bottom: auto;
      left: auto;
      width: 100%;
      max-width: 100%;
      margin: 0;
      transform: none;
    }

    .trip-timeline__node--future {
      position: relative;
      top: auto;
      bottom: auto;
      left: auto;
      width: 100%;
      flex-direction: row;
      justify-content: flex-start;
      padding: 0.5rem 0 0.5rem 1.5rem;
      gap: 0.75rem;
      transform: none;
    }

    .trip-timeline__dot--ghost {
      position: absolute;
      left: 0.25rem;
      top: 0.9rem;
      transform: none;
    }

    .trip-timeline__future-label {
      flex-direction: row;
      gap: 0.25rem;
      margin-top: 0;
    }
  }

  /* ---- Empty state ---- */
  .gallery-empty {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 18rem;
    text-align: center;
    padding: 3rem;
  }

  .gallery-empty p {
    margin: 0;
    color: var(--ch-fg-muted);
    font-size: 1.05rem;
    line-height: 2;
    font-family: var(--ch-display-font);
  }
</style>
