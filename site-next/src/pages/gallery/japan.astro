---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GalleryLightbox from '../../components/GalleryLightbox.astro';
import GalleryImage from '../../components/GalleryImage.astro';
import { resolveGalleryImage, resolveGalleryImages } from '../../utils/gallery-images';

const base = import.meta.env.BASE_URL;

const allEntries = await getCollection('gallery', ({ data }) => !data.draft);

const cityOrder = ['osaka', 'nara', 'uji', 'kyoto', 'kobe', 'himeji'] as const;

const cityMeta: Record<string, { kanji: string; en: string; color: string; desc: string }> = {
  osaka:   { kanji: '大阪', en: 'Osaka',   color: '#e60012', desc: '道頓堀的霓虹、大阪城的绿意、通天阁下的昭和记忆。' },
  nara:    { kanji: '奈良', en: 'Nara',    color: '#8b4513', desc: '春日大社的石灯笼、东大寺的巨佛、若草山的小鹿。' },
  uji:     { kanji: '宇治', en: 'Uji',     color: '#4a9e6e', desc: '宇治川的清流、平等院凤凰堂、中村藤吉的抹茶。' },
  kyoto:   { kanji: '京都', en: 'Kyoto',   color: '#5a9e4b', desc: '岚山的竹林、金阁寺的倒影、伏见稻荷的千本鸟居。' },
  kobe:    { kanji: '神戸', en: 'Kobe',    color: '#0066b3', desc: '港塔的暮色、美利坚公园的海风、摩耶山的夜景。' },
  himeji:  { kanji: '姫路', en: 'Himeji',  color: '#9e9e9e', desc: '白鹭城的天守阁、好古园的枯山水、日本第一名城。' },
};

const citySlugSet = new Set(cityOrder);

const cityEntries = allEntries.filter((e) => {
  const slug = e.id.split('/').pop()?.replace(/\.md$/, '') || '';
  return citySlugSet.has(slug);
});

const cities = cityOrder
  .map((slug) => {
    const entry = cityEntries.find((e) => {
      const s = e.id.split('/').pop()?.replace(/\.md$/, '') || '';
      return s === slug;
    });
    return { slug, ...cityMeta[slug], entry };
  })
  .filter((c) => c.entry);
---

<BaseLayout
  title="関西旅路 · Kansai Journey | 6ch."
  description="大阪、京都、奈良、宇治、神户、姬路——六座城市，一趟旅程的视觉日记。"
>
  <section class="container page-shell">
    <a class="jg-back" href={`${base}gallery/`}>
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="15 18 9 12 15 6" />
      </svg>
      返回画廊
    </a>

    <header class="page-header">
      <p class="section-kicker">Kansai Journey · 2026</p>
      <h1>関西旅路</h1>
      <p class="section-lead">
        大阪、京都、奈良、宇治、神户、姬路——六座城市，一趟旅程的视觉日记。
        每一帧都是这座千年地域不同侧面的切片。
      </p>
    </header>

    <!-- Hero Carousel -->
    <div class="jg-carousel">
      <div class="jg-carousel__track">
        {
          cities.map((city, i) => (
            <div
              class="jg-carousel__slide"
              data-target={`jg-${city.slug}`}
            >
              <GalleryImage
                asset={resolveGalleryImage(city.entry.data.cover, base)}
                alt={city.kanji}
                sizes="(max-width: 900px) 100vw, 76rem"
                loading={i === 0 ? 'eager' : 'lazy'}
                fetchpriority={i === 0 ? 'high' : 'auto'}
              />
              <div class="jg-carousel__slide-overlay">
                <span class="jg-carousel__city-kanji">{city.kanji}</span>
                <span class="jg-carousel__city-en">{city.en}</span>
              </div>
            </div>
          ))
        }
      </div>

      <button type="button" class="jg-carousel__nav jg-carousel__nav--prev" aria-label="上一张">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="15 18 9 12 15 6" />
        </svg>
      </button>
      <button type="button" class="jg-carousel__nav jg-carousel__nav--next" aria-label="下一张">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="9 18 15 12 9 6" />
        </svg>
      </button>

      <div class="jg-carousel__dots">
        {
          cities.map((_, i) => (
            <button
              type="button"
              class:list={['jg-carousel__dot', { 'is-active': i === 0 }]}
              aria-label={`城市 ${i + 1}`}
            />
          ))
        }
      </div>
    </div>

    <!-- Railway Timeline -->
    <nav class="jg-timeline" aria-label="城市导航">
      <div class="jg-timeline__track">
        {
          cities.map((city, i) => (
            <>
              {i > 0 && <span class="jg-timeline__line" aria-hidden="true" />}
              <button
                type="button"
                class:list={['jg-timeline__stop', { 'is-active': i === 0 }]}
                data-target={`jg-${city.slug}`}
                style={`--stop-color: ${city.color}`}
              >
                <span
                  class="jg-timeline__dot"
                  style={`background: ${i === 0 ? city.color : 'var(--ch-surface-solid)'}; border-color: ${city.color}`}
                />
                <span class="jg-timeline__label">
                  <span class="jg-timeline__label-kanji">{city.kanji}</span>
                  <span class="jg-timeline__label-en">{city.en}</span>
                </span>
              </button>
            </>
          ))
        }
      </div>
    </nav>

    <!-- City Sections -->
    {
      cities.map((city) => {
        const allImages = [city.entry.data.cover, ...city.entry.data.images];
        const imageAssets = resolveGalleryImages(allImages, base);
        const allImageDescs = [city.entry.data.coverDesc ?? '', ...(city.entry.data.imageDescs ?? [])];
        const meta = JSON.stringify({
          images: imageAssets,
          imageDescs: allImageDescs,
          title: `${city.kanji} · ${city.en}`,
          description: city.entry.data.description ?? '',
          category: 'photography',
          date: city.entry.data.date
            ? new Date(city.entry.data.date).toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' })
            : '',
          detailUrl: `${base}gallery/photography/${city.slug}/`,
        });

        return (
          <section
            id={`jg-${city.slug}`}
            class="jg-section"
            style={`--section-accent: ${city.color}`}
          >
            <header class="jg-section__header">
              <h2 class="jg-section__kanji">{city.kanji}</h2>
              <span class="jg-section__en">{city.en}</span>
            </header>
            <p class="jg-section__desc">{city.desc}</p>

            <div class="jg-section__grid">
              {
                allImages.length > 0 ? (
                  imageAssets.map((asset, i) => (
                    <button
                      type="button"
                      data-gallery-meta={meta}
                      data-gallery-index={i}
                    >
                      <GalleryImage
                        asset={asset}
                        alt={`${city.kanji}`}
                        sizes="(max-width: 640px) 100vw, (max-width: 1000px) 50vw, 33vw"
                        loading="lazy"
                      />
                    </button>
                  ))
                ) : (
                  <div class="jg-section__empty">
                    即将上架 · Coming soon
                  </div>
                )
              }
            </div>
          </section>
        );
      })
    }
  </section>

  <GalleryLightbox />
</BaseLayout>

<script>
  import { initGalleryLightbox } from '../../scripts/gallery';
  import { initJapanCarousel, initJapanTimeline, initJapanSections } from '../../scripts/japan-gallery';

  initGalleryLightbox();
  initJapanCarousel();
  initJapanTimeline();
  initJapanSections();
</script>
