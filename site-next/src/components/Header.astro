---
import ForestIcon from './ForestIcon.astro';

const base = import.meta.env.BASE_URL;

const nav = [
  { href: `${base}`, label: '主页', exact: true },
  { href: `${base}notes/`, label: '笔记' },
  { href: `${base}essay/`, label: '杂谈' },
  { href: `${base}projects/`, label: '项目' },
  { href: `${base}tags/`, label: '标签' },
  { href: `${base}about/`, label: '关于' },
];

function isActive(href: string, exact?: boolean) {
  if (exact) return Astro.url.pathname === href || Astro.url.pathname === href.replace(/\/$/, '');
  return Astro.url.pathname.startsWith(href);
}
---

<header class="site-header">
  <div class="container site-header__inner">
    <a class="site-logo" href={base}>
      <span class="site-logo__icon" aria-hidden="true">
        <ForestIcon name="tree" />
      </span>
      <span class="site-logo__text">
        <span class="site-logo__name">6ch.</span>
        <span class="site-logo__tag">林间笔记</span>
      </span>
    </a>

    <nav class="site-nav" id="site-nav" aria-label="主导航">
      {
        nav.map((item) => (
          <a
            href={item.href}
            class:list={['site-nav__link', { 'is-active': isActive(item.href, item.exact) }]}
          >
            {item.label}
          </a>
        ))
      }
    </nav>

    <div class="site-header__actions">
      <button type="button" class="icon-btn" id="search-open" aria-label="搜索">
        <ForestIcon name="search" />
      </button>
      <button type="button" class="icon-btn" id="theme-toggle" aria-label="切换主题">
        <ForestIcon name="sun" class="theme-icon theme-icon--sun" />
        <ForestIcon name="moon" class="theme-icon theme-icon--moon" />
      </button>
      <a class="icon-btn" href="https://github.com/6chHenry" target="_blank" rel="noopener" aria-label="GitHub">
        <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 .5a12 12 0 0 0-3.79 23.4c.6.11.82-.26.82-.58 0-.29-.01-1.04-.02-2.04-3.3.72-4-1.6-4-1.6-.54-1.38-1.33-1.75-1.33-1.75-1.09-.75.08-.73.08-.73 1.2.08 1.83 1.24 1.83 1.24 1.07 1.83 2.81 1.3 3.5 1 .11-.78.42-1.3.76-1.6-2.67-.3-5.47-1.33-5.47-5.93 0-1.31.47-2.38 1.24-3.22-.12-.3-.54-1.52.12-3.17 0 0 1.01-.32 3.3 1.23a11.5 11.5 0 0 1 6 0c2.29-1.55 3.3-1.23 3.3-1.23.66 1.65.24 2.87.12 3.17.77.84 1.24 1.91 1.24 3.22 0 4.61-2.8 5.63-5.48 5.93.43.37.81 1.1.81 2.22 0 1.6-.01 2.89-.01 3.28 0 .32.21.7.82.58A12 12 0 0 0 12 .5z"/></svg>
      </a>
      <button type="button" class="icon-btn icon-btn--menu" id="nav-toggle" aria-label="打开菜单" aria-expanded="false" aria-controls="site-nav">
        <ForestIcon name="menu" class="nav-icon nav-icon--open" />
        <ForestIcon name="close" class="nav-icon nav-icon--close" />
      </button>
    </div>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    height: var(--ch-header-height);
    border-bottom: 1px solid var(--ch-border-soft);
    background: color-mix(in srgb, var(--ch-surface-solid) 78%, transparent);
    backdrop-filter: blur(16px) saturate(1.2);
    -webkit-backdrop-filter: blur(16px) saturate(1.2);
  }

  .site-header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.25rem;
    height: 100%;
  }

  .site-logo {
    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
    color: var(--ch-fg);
    text-decoration: none;
    flex-shrink: 0;
  }

  .site-logo__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.35rem;
    height: 2.35rem;
    border-radius: 12px;
    background: var(--ch-accent-dim);
    color: var(--ch-accent-secondary);
  }

  .site-logo__icon :global(.forest-icon) {
    width: 1.2rem;
    height: 1.2rem;
  }

  .site-logo__text {
    display: flex;
    flex-direction: column;
    line-height: 1.15;
  }

  .site-logo__name {
    font-family: var(--ch-display-font);
    font-size: 1.15rem;
    font-weight: 600;
    letter-spacing: 0.04em;
  }

  .site-logo__tag {
    font-family: var(--ch-mono-font);
    font-size: 0.62rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ch-accent-tertiary);
  }

  .site-nav {
    display: flex;
    gap: 0.25rem;
    flex-wrap: wrap;
  }

  .site-nav__link {
    padding: 0.42rem 0.75rem;
    border-radius: 999px;
    color: var(--ch-fg-muted);
    text-decoration: none;
    font-family: var(--ch-display-font);
    font-size: 0.92rem;
    letter-spacing: 0.03em;
    transition:
      color var(--ch-transition-fast),
      background var(--ch-transition-fast);
  }

  .site-nav__link:hover,
  .site-nav__link.is-active {
    color: var(--ch-accent);
    background: var(--ch-accent-dim);
  }

  .site-header__actions {
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }

  .icon-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 12px;
    border: 1px solid var(--ch-border-soft);
    background: color-mix(in srgb, var(--ch-surface) 80%, transparent);
    color: var(--ch-fg-muted);
    cursor: pointer;
    text-decoration: none;
    transition:
      color var(--ch-transition-fast),
      border-color var(--ch-transition-fast),
      background var(--ch-transition-fast),
      transform var(--ch-transition-fast);
  }

  .icon-btn:hover {
    color: var(--ch-accent-secondary);
    border-color: color-mix(in srgb, var(--ch-accent-secondary) 45%, var(--ch-border));
    background: var(--ch-accent-dim);
    transform: translateY(-1px);
  }

  .icon-btn svg,
  .icon-btn :global(.forest-icon) {
    width: 1.05rem;
    height: 1.05rem;
    fill: currentColor;
  }

  .icon-btn--menu {
    display: none;
  }

  .nav-icon--close,
  .theme-icon--moon {
    display: none;
  }

  :global([data-theme='dark']) .theme-icon--sun {
    display: none;
  }

  :global([data-theme='dark']) .theme-icon--moon {
    display: inline-flex;
  }

  :global(body.nav-open) .nav-icon--open {
    display: none;
  }

  :global(body.nav-open) .nav-icon--close {
    display: inline-flex;
  }

  @media (max-width: 860px) {
    .site-nav {
      display: none;
      position: absolute;
      top: calc(var(--ch-header-height) - 1px);
      left: 0;
      right: 0;
      flex-direction: column;
      gap: 0.35rem;
      padding: 1rem 1.25rem 1.25rem;
      border-bottom: 1px solid var(--ch-border-soft);
      background: color-mix(in srgb, var(--ch-surface-solid) 96%, transparent);
      backdrop-filter: blur(16px);
    }

    :global(body.nav-open) .site-nav {
      display: flex;
    }

    .icon-btn--menu {
      display: inline-flex;
    }

    .site-nav__link {
      padding: 0.65rem 0.85rem;
    }
  }
</style>

<script>
  import { initThemeToggle } from '../scripts/theme';
  initThemeToggle();

  const toggle = document.getElementById('nav-toggle');
  const nav = document.getElementById('site-nav');
  toggle?.addEventListener('click', () => {
    const open = document.body.classList.toggle('nav-open');
    toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
    toggle.setAttribute('aria-label', open ? '关闭菜单' : '打开菜单');
  });

  nav?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      document.body.classList.remove('nav-open');
      toggle?.setAttribute('aria-expanded', 'false');
    });
  });
</script>
