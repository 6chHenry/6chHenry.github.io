</style>

<script>
  const root = document.querySelector<HTMLElement>('.paimon-case');

  if (root) {
    const buttons = [...root.querySelectorAll<HTMLButtonElement>('[data-lang-button]')];
    const panels = [...root.querySelectorAll<HTMLElement>('[data-lang-panel]')];

    const setLanguage = (lang: string) => {
      root.dataset.lang = lang;
      panels.forEach((panel) => {
        panel.hidden = panel.dataset.langPanel !== lang;
      });
      buttons.forEach((button) => {
        button.setAttribute('aria-pressed', button.dataset.langButton === lang ? 'true' : 'false');
      });
      try {
        localStorage.setItem('paimon-case-lang', lang);
      } catch {
        // Ignore storage failures; the page still works in the current session.
      }
    };

    buttons.forEach((button) => {
      button.addEventListener('click', () => setLanguage(button.dataset.langButton ?? 'zh'));
    });

    try {
      const saved = localStorage.getItem('paimon-case-lang');
      if (saved === 'en') setLanguage('en');
    } catch {
      setLanguage('zh');
    }
  }
</script>
