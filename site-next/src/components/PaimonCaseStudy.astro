---
import type { CollectionEntry } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

interface ArticleNavLink {
  title: string;
  href: string;
  description?: string;
}

interface Props {
  entry: CollectionEntry<'projects'>;
  previous?: ArticleNavLink;
  next?: ArticleNavLink;
}

const { entry, previous, next } = Astro.props;
const base = import.meta.env.BASE_URL;
const assetBase = `${base}assets/projects/paimon-asks-everything/`;
const journeyAssetBase = `${base}assets/projects/PaimonAsksEverything/paimon-asks-everything.assets/`;
const resolveHref = (href: string) => (href.startsWith('/') ? `${base}${href.slice(1)}` : href);

const links = entry.data.links ?? [];
const liveLink = links.find((link) => link.type === 'demo');
const repoLink = links.find((link) => link.type === 'repo');
const techStack = entry.data.techStack ?? [];

const copy = {
  zh: {
    langLabel: '中文',
    pageTitle: '派蒙三千问',
    pageSubtitle: 'Paimon Asks Everything',
    kicker: 'Case Study / Version Intelligence',
    version: 'MAIN · C55FC57 · 2026.07.15',
    summary:
      '一个面向《原神》国际化发行场景的双语版本理解 Agent：先按地区与旅行者身份组织预热，再用受控检索和原生 Web Search 回答玩家，最后把匿名信号整理成可执行的制作动作。',
    demo: '在线体验',
    github: 'GitHub',
    exhibit: {
      eyebrow: 'Live Product / Main',
      title: '从玩家理解到发行决策的证据闭环',
      notes: ['08 个地区', '03 类旅行者', '02 条搜索链路'],
    },
    overview: {
      label: 'Overview',
      title: '它不只回答一个问题，而是连接一次版本发布的两端',
      text:
        '玩家一端需要无剧透地接回复杂世界观，制作组一端需要知道大家究竟在哪里没看懂。PAIMON 把这两件事做成同一条回路：个性化预热建立语境，证据问答解决理解断点，关系图帮助继续探索，最小化匿名事件再汇总为发行简报与制作清单。',
    },
    problem: {
      label: 'Problem',
      title: '版本越大，真正稀缺的不是内容，而是被正确理解的路径',
      cards: [
        '新玩家、回归玩家和剧情党需要不同的背景深度；统一导览既容易剧透，也容易漏掉关键上下文。',
        '任务文本、官方前瞻、Wiki 与社区讨论混在一起时，流畅回答很容易把推测写成设定。',
        '发行侧看到点击与问题数量，却不一定知道该补哪段时间线、谁最受影响、两周内能做什么。',
      ],
    },
    metrics: {
      label: 'Live System',
      title: '把个性化、检索与隐私约束做成明确参数',
      items: [
        {
          value: '08',
          label: '地区导览',
          text: '从蒙德到至冬，每个地区都有独立阵营、剧情脉络与后续引子。',
        },
        {
          value: '03',
          label: '旅行者身份',
          text: '新玩家、回归玩家、剧情党看到真正不同的内容深度与证据层级。',
        },
        {
          value: '02',
          label: '检索路径',
          text: '自研受控检索与 Anthropic 原生 Web Search 可按次切换并有界回退。',
        },
        {
          value: '00',
          label: '默认保存原始问题',
          text: '只记录最小匿名枚举；用户明确授权后才保留问题文本用于 FAQ 改进。',
        },
      ],
    },
    journey: {
      label: 'Product Journey',
      title: '四站任务线，把“看懂版本”变成可追踪的产品体验',
      lead:
        '这不是四个彼此独立的 Demo 页面。它们从建立上下文开始，经过查证、探索，再回到制作决策，形成一条双向的信息路线。',
      items: [
        {
          signal: 'Context / Preheat',
          title: '先认识旅行者，再决定讲到哪里',
          text: '地区与身份不只改变标题，而是决定阵营入门、剧情回顾、时间线、证据和关系图的开放程度。',
          details: ['八地区独立导览', '三套角色化视图', 'Level 3 剧透二次确认'],
          asset: 'preheat.webp',
          kind: 'screen',
          alt: '版本预热页面：八个地区与新玩家、回归玩家、剧情党三类身份选择。',
          caption: '版本预热 / 地区 × 旅行者身份',
        },
        {
          signal: 'Ask / Evidence',
          title: '先查证，再让派蒙开口',
          text: '问题先经过意图识别、别名扩展与剧透门控，再进入可切换的两条搜索链路；来源去重、分级并通过引用校验后才生成回答。',
          details: ['自研检索 / 原生 Web Search', '真实 URL 与来源分级', '失败时一次有界回退'],
          asset: 'ask.webp',
          kind: 'screen',
          alt: '问派蒙页面：问题输入、两种搜索模式、地区与剧情专题建议。',
          caption: '问派蒙 / 可切换搜索与上下文建议',
        },
        {
          signal: 'Explore / Graph',
          title: '把角色与伏笔放回关系里',
          text: '至冬关系图把角色、组织和概念做成可探索节点；节点详情、关系分析与文本线索共同指向证据等级，而不是只展示漂亮连线。',
          details: ['多语言节点详情', '双节点关系分析', '文本线索溯源'],
          asset: 'design-map.png',
          kind: 'map',
          alt: '派蒙三千问设计思维导图，连接玩家向导、证据问答、关系图与发行观察。',
          caption: '系统地图 / 玩家价值与发行价值共享同一证据底座',
        },
        {
          signal: 'Decide / Release',
          title: '把匿名信号变成下一步动作',
          text: '决策台不止汇总次数，而是给出玩家需求切片、机会与风险分数，以及带负责人、排期和验收标准的制作动作。',
          details: ['AI 中文制作组简报', '确定性机会 / 风险评分', '证据越界自动回退规则版'],
          asset: 'insights.webp',
          kind: 'screen',
          alt: '发行洞察页面：未来两到四周发布建议与制作动作简报。',
          caption: '发行洞察 / 从信号到可审核制作动作',
        },
      ],
    },
    chain: {
      label: 'Evidence Chain',
      title: '每个结论都要沿原路走回证据',
      lead:
        '默认路径从用户偏好开始，到证据回答结束；只有最小匿名信号会继续进入发行侧。模型不可用、引用越界或搜索不完整时，系统会显式降级，而不是用更自信的语气遮住失败。',
      items: ['身份与地区', '主题编排', '受控检索', '原生搜索', '来源治理', '引用校验', '证据回答', '匿名决策信号'],
    },
    reliability: {
      label: 'Reliability',
      title: '可信度不是一句承诺，而是失败路径也经过设计',
      items: [
        '官方、可信 Wiki、社区与未知网页分层处理，社区推测不会被包装成官方设定。',
        '无最终正文、来源无关、请求超时或截断时，每次请求最多回退一次，并清理无法映射的引用编号。',
        '没有模型密钥时仍可运行确定性证据回答；没有 Supabase 时切换到本地事件存储。',
        'Vitest 固定覆盖剧透 token、双语检索、引用完整性、三类预热视图、图谱证据与发行规则。',
      ],
    },
    retrospective: {
      label: 'Current State',
      title: '已经上线，也把边界写在产品里',
      text:
        '截至 main@c55fc57，个性化预热、双搜索链路、引用治理、关系图和发行决策台都已进入公开 Demo。已知限制仍包括 Vercel 冷启动、站外趋势层尚未接入、进程内轻量限流，以及社区 Wiki 本身的覆盖边界；页面会明确降级，不把这些限制藏在顺滑文案后面。',
    },
    nav: {
      previous: '上一篇',
      next: '下一篇',
    },
  },
  en: {
    langLabel: 'EN',
    pageTitle: 'Paimon Asks Everything',
    pageSubtitle: 'Paimon Sanqianwen',
    kicker: 'Case Study / Version Intelligence',
    version: 'MAIN · C55FC57 · 2026.07.15',
    summary:
      'A bilingual version-intelligence agent for Genshin publishing: personalize preheat by region and traveler profile, answer through governed retrieval and native Web Search, then turn anonymous signals into reviewable production actions.',
    demo: 'Live Demo',
    github: 'GitHub',
    exhibit: {
      eyebrow: 'Live Product / Main',
      title: 'An evidence loop from player clarity to release decisions',
      notes: ['08 regions', '03 traveler profiles', '02 search routes'],
    },
    overview: {
      label: 'Overview',
      title: 'It connects both ends of a release, not just one question.',
      text:
        'Players need to re-enter a dense world without being spoiled. Release teams need to know where understanding breaks. PAIMON turns both needs into one loop: personalized preheat establishes context, evidence Q&A resolves confusion, the relationship graph supports exploration, and minimal anonymous events become release briefs and production checklists.',
    },
    problem: {
      label: 'Problem',
      title: 'As releases grow, the scarce resource is a path to correct understanding.',
      cards: [
        'New, returning, and lore-focused players need different context depth; one briefing either spoils too much or explains too little.',
        'Quest text, official previews, wikis, and community threads blur together, so fluent answers can quietly turn speculation into canon.',
        'Counts alone do not tell a release team which timeline to clarify, who is affected, or what can ship in the next two weeks.',
      ],
    },
    metrics: {
      label: 'Live System',
      title: 'Personalization, retrieval, and privacy are explicit parameters.',
      items: [
        {
          value: '08',
          label: 'Region guides',
          text: 'Every region from Mondstadt to Snezhnaya has its own factions, story path, and forward hook.',
        },
        {
          value: '03',
          label: 'Traveler profiles',
          text: 'New, returning, and lore-focused players receive genuinely different depth and evidence views.',
        },
        {
          value: '02',
          label: 'Search routes',
          text: 'A controlled in-house route and Anthropic native Web Search switch per request with bounded fallback.',
        },
        {
          value: '00',
          label: 'Raw questions stored by default',
          text: 'Only minimal anonymous enums are logged; question text requires explicit opt-in for FAQ improvement.',
        },
      ],
    },
    journey: {
      label: 'Product Journey',
      title: 'Four mission stops turn “understand the update” into a traceable experience.',
      lead:
        'These are not four disconnected demo pages. They establish context, verify claims, support exploration, and return evidence to production decisions as one two-way information route.',
      items: [
        {
          signal: 'Context / Preheat',
          title: 'Know the traveler before choosing what to reveal.',
          text: 'Region and profile determine which faction primer, recap, timeline, evidence, and graph layers are actually shown.',
          details: ['Eight independent region guides', 'Three role-specific views', 'Second confirmation for level-three spoilers'],
          asset: 'preheat.webp',
          kind: 'screen',
          alt: 'Preheat page with eight regions and new, returning, and lore-focused traveler profiles.',
          caption: 'Version preheat / Region × traveler profile',
        },
        {
          signal: 'Ask / Evidence',
          title: 'Verify first. Let Paimon speak second.',
          text: 'Intent, alias expansion, and spoiler gates precede two switchable search routes. Sources are deduplicated, graded, and citation-checked before generation.',
          details: ['Controlled search / native Web Search', 'Real URLs and source tiers', 'One bounded fallback on failure'],
          asset: 'ask.webp',
          kind: 'screen',
          alt: 'Ask Paimon page with question composer, two search modes, and region and story suggestions.',
          caption: 'Ask Paimon / Switchable search with contextual prompts',
        },
        {
          signal: 'Explore / Graph',
          title: 'Put characters and clues back into relationships.',
          text: 'The Snezhnaya graph turns characters, factions, and concepts into explorable nodes. Details, pair analysis, and text trails point back to evidence grades—not decorative lines.',
          details: ['Bilingual node details', 'Two-node relationship analysis', 'Traceable text clues'],
          asset: 'design-map.png',
          kind: 'map',
          alt: 'PAIMON design map connecting player guidance, evidence Q&A, relationship exploration, and release observation.',
          caption: 'System map / Player and release value share one evidence base',
        },
        {
          signal: 'Decide / Release',
          title: 'Turn anonymous signals into the next production action.',
          text: 'The decision center goes beyond counts: player-demand slices, opportunity and risk scores, plus actions with owners, schedules, and acceptance criteria.',
          details: ['Chinese AI production brief', 'Deterministic opportunity / risk scores', 'Rule fallback when citations leave the whitelist'],
          asset: 'insights.webp',
          kind: 'screen',
          alt: 'Release insights page with a two-to-four-week publishing recommendation and production brief.',
          caption: 'Release insights / From signals to reviewable actions',
        },
      ],
    },
    chain: {
      label: 'Evidence Chain',
      title: 'Every conclusion has to walk back to evidence.',
      lead:
        'The default path starts with player context and ends with an evidence answer; only a minimal anonymous signal continues to the release side. When models fail, citations leave the whitelist, or search results are incomplete, the system degrades explicitly instead of hiding failure behind confidence.',
      items: ['Profile + region', 'Topic orchestration', 'Controlled retrieval', 'Native search', 'Source governance', 'Citation validation', 'Evidence answer', 'Anonymous decision signal'],
    },
    reliability: {
      label: 'Reliability',
      title: 'Trust is not a promise. Failure paths are designed too.',
      items: [
        'Official, trusted-wiki, community, and unknown-web sources are separated, so community theories do not become official canon.',
        'Missing final text, irrelevant sources, timeouts, and truncation trigger at most one fallback; unmapped citation numbers are removed.',
        'Without a model key the deterministic evidence answer still runs; without Supabase the event layer falls back to local storage.',
        'Vitest covers spoiler tokens, bilingual retrieval, citation integrity, three preheat views, graph evidence, and release rules.',
      ],
    },
    retrospective: {
      label: 'Current State',
      title: 'Live today, with its boundaries visible.',
      text:
        'As of main@c55fc57, personalized preheat, both search routes, citation governance, the relationship graph, and the release decision center are live in the public demo. Known limits remain: Vercel cold starts, an external-trend layer still awaiting integration, process-local rate limiting, and the coverage ceiling of community wikis. The interface degrades clearly instead of hiding those constraints.',
    },
    nav: {
      previous: 'Previous',
      next: 'Next',
    },
  },
};

const languages = ['zh', 'en'] as const;
---

<BaseLayout title={`派蒙三千问 | ${entry.data.title}`} description={entry.data.description}>
  <article class="paimon-case" data-lang="zh" data-pagefind-body>
    <section class="paimon-hero" aria-labelledby="paimon-title-zh">
      <div class="paimon-hero__copy">
        <div class="paimon-topline">
          <p class="section-kicker">{copy.zh.kicker}</p>
          <div class="paimon-language" role="group" aria-label="Language">
            {
              languages.map((lang) => (
                <button type="button" class="paimon-language__button" data-lang-button={lang} aria-pressed={lang === 'zh' ? 'true' : 'false'}>
                  {copy[lang].langLabel}
                </button>
              ))
            }
          </div>
        </div>

        {
          languages.map((lang) => (
            <div class="paimon-copy-panel" data-lang-panel={lang} hidden={lang !== 'zh'}>
              <h1 id={lang === 'zh' ? 'paimon-title-zh' : undefined}>{copy[lang].pageTitle}</h1>
              <p class="paimon-hero__subtitle">{copy[lang].pageSubtitle}</p>
              <p class="paimon-version-stamp">{copy[lang].version}</p>
              <p class="paimon-hero__summary">{copy[lang].summary}</p>
            </div>
          ))
        }

        <div class="paimon-hero__actions" aria-label="Project links">
          {
            liveLink && (
              <a class="paimon-link paimon-link--primary" href={resolveHref(liveLink.href)} target="_blank" rel="noopener">
                <span data-lang-panel="zh">{copy.zh.demo}</span>
                <span data-lang-panel="en" hidden>{copy.en.demo}</span>
              </a>
            )
          }
          {
            repoLink && (
              <a class="paimon-link" href={resolveHref(repoLink.href)} target="_blank" rel="noopener">
                {copy.zh.github}
              </a>
            )
          }
        </div>
        <ul class="paimon-meta" aria-label="Project metadata">
          {techStack.slice(0, 4).map((tech) => <li>{tech}</li>)}
        </ul>
      </div>

      <div class="paimon-hero__gallery">
        <figure class="paimon-hero__visual">
          <img
            src={`${assetBase}banner.png`}
            alt="Paimon Asks Everything promotional banner showing Paimon, a starry blue background, and four product feature cards."
            width="2048"
            height="680"
            loading="eager"
            decoding="async"
          />
          <figcaption class="paimon-exhibit-card">
            {
              languages.map((lang) => (
                <span data-lang-panel={lang} hidden={lang !== 'zh'}>
                  <span>{copy[lang].exhibit.eyebrow}</span>
                  <strong>{copy[lang].exhibit.title}</strong>
                </span>
              ))
            }
          </figcaption>
        </figure>
        {
          languages.map((lang) => (
            <div class="paimon-annotations" data-lang-panel={lang} hidden={lang !== 'zh'} aria-hidden="true">
              {copy[lang].exhibit.notes.map((note) => <span>{note}</span>)}
            </div>
          ))
        }
      </div>
    </section>

    {
      languages.map((lang) => (
        <div class="paimon-copy-panel" data-lang-panel={lang} hidden={lang !== 'zh'}>
          <section class="paimon-section paimon-overview">
            <div class="paimon-section__heading">
              <p class="paimon-label">{copy[lang].overview.label}</p>
              <h2>{copy[lang].overview.title}</h2>
            </div>
            <p>{copy[lang].overview.text}</p>
          </section>

          <section class="paimon-section">
            <div class="paimon-section__heading">
              <p class="paimon-label">{copy[lang].problem.label}</p>
              <h2>{copy[lang].problem.title}</h2>
            </div>
            <div class="paimon-problem-grid">
              {copy[lang].problem.cards.map((item) => <p>{item}</p>)}
            </div>
          </section>

          <section class="paimon-section">
            <div class="paimon-section__heading">
              <p class="paimon-label">{copy[lang].metrics.label}</p>
              <h2>{copy[lang].metrics.title}</h2>
            </div>
            <div class="paimon-signal-grid">
              {copy[lang].metrics.items.map((metric) => (
                <article class="paimon-signal">
                  <strong>{metric.value}</strong>
                  <h3>{metric.label}</h3>
                  <p>{metric.text}</p>
                </article>
              ))}
            </div>
          </section>

          <section id={`product-journey-${lang}`} class="paimon-section paimon-journey-section">
            <div class="paimon-section__heading">
              <p class="paimon-label">{copy[lang].journey.label}</p>
              <h2>{copy[lang].journey.title}</h2>
              <p class="paimon-section__lead">{copy[lang].journey.lead}</p>
            </div>
            <div class="paimon-journey">
              {copy[lang].journey.items.map((stage, index) => (
                <article class="paimon-journey__item">
                  <div class="paimon-journey__copy">
                    <div class="paimon-journey__index">
                      <span>{String(index + 1).padStart(2, '0')}</span>
                      <small>{stage.signal}</small>
                    </div>
                    <h3>{stage.title}</h3>
                    <p>{stage.text}</p>
                    <ul>
                      {stage.details.map((detail) => <li>{detail}</li>)}
                    </ul>
                  </div>
                  <figure class={`paimon-journey__visual paimon-journey__visual--${stage.kind}`}>
                    <img
                      src={stage.kind === 'screen' ? `${journeyAssetBase}${stage.asset}` : `${assetBase}${stage.asset}`}
                      alt={stage.alt}
                      width={stage.kind === 'screen' ? 1200 : 1794}
                      height={stage.kind === 'screen' ? 833 : 1356}
                      loading="lazy"
                      decoding="async"
                    />
                    <figcaption>
                      <span>{stage.signal}</span>
                      <strong>{stage.caption}</strong>
                    </figcaption>
                  </figure>
                </article>
              ))}
            </div>
          </section>

          <section id={`evidence-chain-${lang}`} class="paimon-section paimon-chain-section">
            <div class="paimon-section__heading">
              <p class="paimon-label">{copy[lang].chain.label}</p>
              <h2>{copy[lang].chain.title}</h2>
            </div>
            <div>
              <p class="paimon-chain-lead">{copy[lang].chain.lead}</p>
              <ol class="paimon-evidence-chain" aria-label={copy[lang].chain.label}>
                {copy[lang].chain.items.map((item, index) => (
                  <li>
                    <span>{String(index + 1).padStart(2, '0')}</span>
                    <strong>{item}</strong>
                  </li>
                ))}
              </ol>
            </div>
          </section>

          <section id={`reliability-${lang}`} class="paimon-section paimon-reliability">
            <div class="paimon-section__heading">
              <p class="paimon-label">{copy[lang].reliability.label}</p>
              <h2>{copy[lang].reliability.title}</h2>
            </div>
            <ul>
              {copy[lang].reliability.items.map((item) => <li>{item}</li>)}
            </ul>
          </section>

          <section class="paimon-section paimon-retrospective paimon-current-state">
            <div class="paimon-section__heading">
              <p class="paimon-label">{copy[lang].retrospective.label}</p>
              <h2>{copy[lang].retrospective.title}</h2>
            </div>
            <div class="paimon-section__body">
              <p>{copy[lang].retrospective.text}</p>
            </div>
          </section>
        </div>
      ))
    }

    {
      (previous || next) && (
        <nav class="paimon-nav" aria-label="Project navigation">
          {previous ? (
            <a href={previous.href}>
              <span data-lang-panel="zh">{copy.zh.nav.previous}</span>
              <span data-lang-panel="en" hidden>{copy.en.nav.previous}</span>
              <strong>{previous.title}</strong>
            </a>
          ) : (
            <span></span>
          )}
          {next ? (
            <a href={next.href}>
              <span data-lang-panel="zh">{copy.zh.nav.next}</span>
              <span data-lang-panel="en" hidden>{copy.en.nav.next}</span>
              <strong>{next.title}</strong>
            </a>
          ) : (
            <span></span>
          )}
        </nav>
      )
    }
  </article>
</BaseLayout>

<style>
