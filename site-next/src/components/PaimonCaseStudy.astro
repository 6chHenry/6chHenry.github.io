---
import type { CollectionEntry } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

interface ArticleNavLink {
  title: string;
  href: string;
  description?: string;
}

interface Props {
  entry: CollectionEntry<'projects'>;
  previous?: ArticleNavLink;
  next?: ArticleNavLink;
}

const { entry, previous, next } = Astro.props;
const base = import.meta.env.BASE_URL;
const assetBase = `${base}assets/projects/paimon-asks-everything/`;
const resolveHref = (href: string) => (href.startsWith('/') ? `${base}${href.slice(1)}` : href);

const links = entry.data.links ?? [];
const liveLink = links.find((link) => link.type === 'demo');
const repoLink = links.find((link) => link.type === 'repo');
const techStack = entry.data.techStack ?? [];

const copy = {
  zh: {
    langLabel: '中文',
    pageTitle: '派蒙三千问',
    pageSubtitle: 'Paimon Asks Everything',
    kicker: 'Case Study / AI Agent',
    summary:
      '一个面向原神玩家与发行观察的双语证据型 Agent：它不急着生成答案，而是先判断进度、控制剧透、检索来源，再把可追溯的证据组织成回答。',
    demo: '在线体验',
    github: 'GitHub',
    exhibit: {
      eyebrow: 'Project Artifact',
      title: '剧透安全的游戏理解系统',
      notes: ['双语检索', '来源分级', '结构化引用'],
    },
    overview: {
      label: 'Overview',
      title: '我想做的不是一个聊天框，而是一套有边界的理解系统',
      text:
        '《原神》的故事信息散落在任务、版本活动、圣遗物、角色资料、Wiki 和社区讨论里。普通问答很容易把玩家还没玩到的剧情直接说破，也容易把推测写得像事实。我把这个项目设计成“派蒙作为向导”的产品：先确认玩家语境，再决定能说什么、从哪里查、证据够不够、应该如何降级表达。',
    },
    problem: {
      label: 'Problem',
      title: '玩家想问清楚，系统必须先学会克制',
      cards: [
        '同一个问题，对新玩家、回归玩家和活跃玩家意味着不同的剧透风险。',
        '中文和英文资料并不总是同构，实体别名、版本边界和社区说法会互相缠绕。',
        '发行侧真正需要的不是原始聊天记录，而是哪些主题反复造成理解断点。',
      ],
    },
    pillars: {
      label: 'Product Strategy',
      title: '四个模块把创意落到可验证体验',
      items: [
        {
          label: '剧透安全问答',
          text: '回答跟随玩家进度，遇到高风险剧情先停下，必要时要求二次确认。',
        },
        {
          label: '证据约束回答',
          text: '每个结论都尽量回到来源、引用和置信边界，而不是让模型凭语气取胜。',
        },
        {
          label: '至冬关系图',
          text: '把人物、组织、概念做成可探索节点，让复杂世界观从碎片变成关系。',
        },
        {
          label: '发行洞察',
          text: '用匿名聚合信号识别兴趣点、误解点和 FAQ 机会，而不是保存个人问题。',
        },
      ],
    },
    chain: {
      label: 'Evidence Chain',
      title: '核心创意是一条“先证据，后生成”的链',
      lead:
        '我把 Agent 的工作流设计成一条证据链：用户问题进入后，先经过语境判断与剧透门控，再检索、分级、引用，最后才进入生成。这样页面里的每个回答都像一张可回看的研究卡片。',
      items: ['玩家问题', '剧透门控', '双语检索', '来源分级', '证据回答', '匿名洞察'],
    },
    map: {
      label: 'System Design',
      title: '从“派蒙笔记 AI 化”到发行观察窗口',
      caption:
        '这张图保留了最初的产品思路：派蒙是向导，不是替代游戏体验；准确性高于顺滑表达；发行价值来自玩家真正卡住的地方。',
    },
    reliability: {
      label: 'Reliability',
      title: '让 Demo 诚实，比让它显得聪明更重要',
      items: [
        '引用校验先于“看起来很完整”的回答。',
        '来源被分为官方、可信 Wiki、社区与未知网页，社区索引不会被包装成官方事实。',
        '证据不足时降低置信度或拒答，而不是补写确定口吻。',
        '固定问题集覆盖检索、剧透、引用、限流和事件写入的回归检查。',
      ],
    },
    retrospective: {
      label: 'Retrospective',
      title: '下一步我会继续增强“游戏感”和“可信度”之间的平衡',
      text:
        '现在的公开 Demo 仍有 Vercel 冷启动、站外趋势层未完全接入、轻量限流等限制。下一步我会让 UI 更贴近游戏语境，同时继续强化本地语料、搜索稳定性和派蒙式表达的一致性。',
    },
    nav: {
      previous: '上一篇',
      next: '下一篇',
    },
  },
  en: {
    langLabel: 'EN',
    pageTitle: 'Paimon Asks Everything',
    pageSubtitle: 'Paimon Sanqianwen',
    kicker: 'Case Study / AI Agent',
    summary:
      'A bilingual evidence-grounded agent for Genshin players and release insight exploration. It does not rush to generate. It checks progress, gates spoilers, retrieves sources, and turns traceable evidence into answers.',
    demo: 'Live Demo',
    github: 'GitHub',
    exhibit: {
      eyebrow: 'Project Artifact',
      title: 'A spoiler-safe game understanding system',
      notes: ['Bilingual retrieval', 'Source governance', 'Structured citations'],
    },
    overview: {
      label: 'Overview',
      title: 'I was not building a chat box. I was building a bounded understanding system.',
      text:
        'Genshin lore lives across quests, version events, artifacts, character profiles, wikis, and community threads. A normal Q&A interface can easily spoil players or present speculation as fact. I shaped the project around Paimon as a guide: understand player context first, decide what can be said, choose where to search, judge whether evidence is enough, then answer with clear boundaries.',
    },
    problem: {
      label: 'Problem',
      title: 'Players want clarity. The system has to learn restraint first.',
      cards: [
        'The same question carries different spoiler risk for new, returning, and active players.',
        'Chinese and English sources do not always align across aliases, version boundaries, and community wording.',
        'Release teams need aggregate confusion signals, not raw personal question logs.',
      ],
    },
    pillars: {
      label: 'Product Strategy',
      title: 'Four modules turn the idea into a testable experience',
      items: [
        {
          label: 'Spoiler-safe Q&A',
          text: 'Answers adapt to player progress and stop before high-risk narrative reveals.',
        },
        {
          label: 'Evidence-grounded answers',
          text: 'Claims are tied back to sources, citations, and confidence boundaries instead of fluent guesswork.',
        },
        {
          label: 'Snezhnaya relationship map',
          text: 'Characters, factions, and concepts become explorable nodes instead of scattered notes.',
        },
        {
          label: 'Release insights',
          text: 'Anonymous aggregate signals reveal interest, confusion, and FAQ opportunities without storing personal questions.',
        },
      ],
    },
    chain: {
      label: 'Evidence Chain',
      title: 'The core idea is evidence before generation',
      lead:
        'I designed the agent workflow as an evidence chain: a question enters, passes context and spoiler gates, then retrieval, source grading, citation checks, and only finally generation. Each answer behaves like a research card you can audit.',
      items: ['Player question', 'Spoiler gate', 'Bilingual retrieval', 'Source grading', 'Evidence answer', 'Anonymous insight'],
    },
    map: {
      label: 'System Design',
      title: 'From Paimon notebook AI to a release observation window',
      caption:
        'The map captures the original product thesis: Paimon is a guide, not a replacement for play; accuracy beats fluency; release value emerges from the places where players actually get stuck.',
    },
    reliability: {
      label: 'Reliability',
      title: 'Making the demo honest matters more than making it sound smart',
      items: [
        'Citation validation comes before answers that merely look complete.',
        'Sources are separated into official, trusted wiki, community, and unknown web material.',
        'Weak evidence lowers confidence or triggers refusal instead of certainty.',
        'A fixed evaluation set checks retrieval, spoilers, citations, rate limits, and event writing.',
      ],
    },
    retrospective: {
      label: 'Retrospective',
      title: 'Next I would keep balancing game feel with trustworthiness',
      text:
        'The public demo still has Vercel cold-start limits, an unfinished external trend layer, and lightweight rate limiting. Next I would push the interface closer to the game while strengthening the local corpus, search reliability, and Paimon-style voice consistency.',
    },
    nav: {
      previous: 'Previous',
      next: 'Next',
    },
  },
};

const languages = ['zh', 'en'] as const;
---

<BaseLayout title={`派蒙三千问 | ${entry.data.title}`} description={entry.data.description}>
  <article class="paimon-case" data-lang="zh" data-pagefind-body>
    <section class="paimon-hero" aria-labelledby="paimon-title-zh">
      <div class="paimon-hero__copy">
        <div class="paimon-topline">
          <p class="section-kicker">{copy.zh.kicker}</p>
          <div class="paimon-language" role="group" aria-label="Language">
            {
              languages.map((lang) => (
                <button type="button" class="paimon-language__button" data-lang-button={lang} aria-pressed={lang === 'zh' ? 'true' : 'false'}>
                  {copy[lang].langLabel}
                </button>
              ))
            }
          </div>
        </div>

        {
          languages.map((lang) => (
            <div class="paimon-copy-panel" data-lang-panel={lang} hidden={lang !== 'zh'}>
              <h1 id={lang === 'zh' ? 'paimon-title-zh' : undefined}>{copy[lang].pageTitle}</h1>
              <p class="paimon-hero__subtitle">{copy[lang].pageSubtitle}</p>
              <p class="paimon-hero__summary">{copy[lang].summary}</p>
            </div>
          ))
        }

        <div class="paimon-hero__actions" aria-label="Project links">
          {
            liveLink && (
              <a class="paimon-link paimon-link--primary" href={resolveHref(liveLink.href)} target="_blank" rel="noopener">
                <span data-lang-panel="zh">{copy.zh.demo}</span>
                <span data-lang-panel="en" hidden>{copy.en.demo}</span>
              </a>
            )
          }
          {
            repoLink && (
              <a class="paimon-link" href={resolveHref(repoLink.href)} target="_blank" rel="noopener">
                {copy.zh.github}
              </a>
            )
          }
        </div>
        <ul class="paimon-meta" aria-label="Project metadata">
          {techStack.slice(0, 4).map((tech) => <li>{tech}</li>)}
        </ul>
      </div>

      <div class="paimon-hero__gallery">
        <figure class="paimon-hero__visual">
          <img
            src={`${assetBase}banner.png`}
            alt="Paimon Asks Everything promotional banner showing Paimon, a starry blue background, and four product feature cards."
            width="2048"
            height="680"
            loading="eager"
            decoding="async"
          />
          <figcaption class="paimon-exhibit-card">
            {
              languages.map((lang) => (
                <span data-lang-panel={lang} hidden={lang !== 'zh'}>
                  <span>{copy[lang].exhibit.eyebrow}</span>
                  <strong>{copy[lang].exhibit.title}</strong>
                </span>
              ))
            }
          </figcaption>
        </figure>
        <div class="paimon-annotations" aria-hidden="true">
          <span>source.bound</span>
          <span>spoiler.level <= profile</span>
          <span>citation.required</span>
        </div>
      </div>
    </section>

    {
      languages.map((lang) => (
        <div class="paimon-copy-panel" data-lang-panel={lang} hidden={lang !== 'zh'}>
          <section class="paimon-section paimon-overview">
            <div>
              <p class="paimon-label">{copy[lang].overview.label}</p>
              <h2>{copy[lang].overview.title}</h2>
            </div>
            <p>{copy[lang].overview.text}</p>
          </section>

          <section class="paimon-section">
            <div class="paimon-section__heading">
              <p class="paimon-label">{copy[lang].problem.label}</p>
              <h2>{copy[lang].problem.title}</h2>
            </div>
            <div class="paimon-problem-grid">
              {copy[lang].problem.cards.map((item) => <p>{item}</p>)}
            </div>
          </section>

          <section class="paimon-section">
            <div class="paimon-section__heading">
              <p class="paimon-label">{copy[lang].pillars.label}</p>
              <h2>{copy[lang].pillars.title}</h2>
            </div>
            <div class="paimon-pillar-grid">
              {copy[lang].pillars.items.map((pillar, index) => (
                <article class="paimon-pillar">
                  <span>{String(index + 1).padStart(2, '0')}</span>
                  <h3>{pillar.label}</h3>
                  <p>{pillar.text}</p>
                </article>
              ))}
            </div>
          </section>

          <section class="paimon-section paimon-chain-section">
            <div class="paimon-section__heading">
              <p class="paimon-label">{copy[lang].chain.label}</p>
              <h2>{copy[lang].chain.title}</h2>
            </div>
            <div>
              <p class="paimon-chain-lead">{copy[lang].chain.lead}</p>
              <ol class="paimon-evidence-chain" aria-label={copy[lang].chain.label}>
                {copy[lang].chain.items.map((item, index) => (
                  <li>
                    <span>{String(index + 1).padStart(2, '0')}</span>
                    <strong>{item}</strong>
                  </li>
                ))}
              </ol>
            </div>
          </section>

          <section class="paimon-section paimon-map-section">
            <div class="paimon-section__heading">
              <p class="paimon-label">{copy[lang].map.label}</p>
              <h2>{copy[lang].map.title}</h2>
            </div>
            <figure class="paimon-map">
              <img
                src={`${assetBase}design-map.png`}
                alt="Design mind map for Paimon Asks Everything, connecting core positioning, reasons for the product, design principles, release value, Snezhnaya adaptation, and core features."
                width="1794"
                height="1356"
                loading="lazy"
                decoding="async"
              />
              <figcaption>{copy[lang].map.caption}</figcaption>
            </figure>
          </section>

          <section class="paimon-section paimon-reliability">
            <div class="paimon-section__heading">
              <p class="paimon-label">{copy[lang].reliability.label}</p>
              <h2>{copy[lang].reliability.title}</h2>
            </div>
            <ul>
              {copy[lang].reliability.items.map((item) => <li>{item}</li>)}
            </ul>
          </section>

          <section class="paimon-section paimon-retrospective">
            <div>
              <p class="paimon-label">{copy[lang].retrospective.label}</p>
              <h2>{copy[lang].retrospective.title}</h2>
            </div>
            <div>
              <p>{copy[lang].retrospective.text}</p>
            </div>
          </section>
        </div>
      ))
    }

    {
      (previous || next) && (
        <nav class="paimon-nav" aria-label="Project navigation">
          {previous ? (
            <a href={previous.href}>
              <span data-lang-panel="zh">{copy.zh.nav.previous}</span>
              <span data-lang-panel="en" hidden>{copy.en.nav.previous}</span>
              <strong>{previous.title}</strong>
            </a>
          ) : (
            <span></span>
          )}
          {next ? (
            <a href={next.href}>
              <span data-lang-panel="zh">{copy.zh.nav.next}</span>
              <span data-lang-panel="en" hidden>{copy.en.nav.next}</span>
              <strong>{next.title}</strong>
            </a>
          ) : (
            <span></span>
          )}
        </nav>
      )
    }
  </article>
</BaseLayout>

<style>
  .paimon-case {
    --paimon-navy: #07142f;
    --paimon-navy-soft: #12264a;
    --paimon-ink: #0a1a18;
    --paimon-gold: var(--ch-accent-warm);
    --paimon-line: color-mix(in srgb, var(--paimon-gold) 34%, var(--ch-border-soft));
    width: min(calc(100% - 2.5rem), 80rem);
    margin: 0 auto;
    padding: 2.5rem 0 4.5rem;
  }

  .paimon-copy-panel[hidden],
  [data-lang-panel][hidden] {
    display: none !important;
  }

  .paimon-hero {
    position: relative;
    display: grid;
    grid-template-columns: minmax(0, 0.72fr) minmax(20rem, 1fr);
    gap: clamp(1.25rem, 3vw, 2.5rem);
    align-items: center;
    min-height: min(740px, calc(100dvh - var(--ch-header-height) - 0.5rem));
    padding: clamp(1.2rem, 3vw, 2rem);
    overflow: hidden;
    border: 1px solid var(--paimon-line);
    border-radius: 14px;
    background:
      linear-gradient(135deg, color-mix(in srgb, var(--ch-surface-solid) 91%, transparent), color-mix(in srgb, var(--paimon-navy) 16%, var(--ch-glass-bg))),
      linear-gradient(90deg, color-mix(in srgb, var(--paimon-gold) 12%, transparent) 0 1px, transparent 1px 100%),
      linear-gradient(0deg, color-mix(in srgb, var(--ch-accent-secondary) 10%, transparent) 0 1px, transparent 1px 100%);
    background-size: auto, 42px 42px, 42px 42px;
  }

  .paimon-hero::before {
    position: absolute;
    inset: 1rem;
    border: 1px solid color-mix(in srgb, var(--paimon-gold) 20%, transparent);
    border-radius: 10px;
    content: '';
    pointer-events: none;
  }

  .paimon-hero__copy {
    position: relative;
    z-index: 1;
  }

  .paimon-topline {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .paimon-language {
    display: inline-grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    min-height: 44px;
    padding: 0.2rem;
    border: 1px solid var(--paimon-line);
    border-radius: 999px;
    background: color-mix(in srgb, var(--ch-surface-solid) 78%, transparent);
  }

  .paimon-language__button {
    min-width: 3.2rem;
    min-height: 36px;
    border: 0;
    border-radius: 999px;
    background: transparent;
    color: var(--ch-fg-muted);
    cursor: pointer;
    font-family: var(--ch-mono-font);
    font-size: 0.68rem;
    letter-spacing: 0.08em;
  }

  .paimon-language__button[aria-pressed='true'] {
    background: color-mix(in srgb, var(--paimon-gold) 22%, var(--ch-surface-solid));
    color: var(--ch-accent-ink);
  }

  .paimon-hero h1,
  .paimon-section h2 {
    color: var(--ch-fg);
    font-family: var(--ch-display-font);
  }

  .paimon-hero h1 {
    margin: 0;
    font-size: clamp(3.4rem, 8.5vw, 7rem);
    line-height: 0.92;
  }

  .paimon-hero__subtitle {
    margin: 0.8rem 0 0;
    color: var(--paimon-gold);
    font-family: var(--ch-mono-font);
    font-size: 0.82rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .paimon-hero__summary,
  .paimon-section p,
  .paimon-pillar p,
  .paimon-chain-lead,
  .paimon-map figcaption,
  .paimon-reliability li {
    color: var(--ch-fg-muted);
    line-height: 1.76;
  }

  .paimon-hero__summary {
    max-width: 35rem;
    margin: 1.1rem 0 0;
    font-size: 1.06rem;
  }

  .paimon-hero__actions,
  .paimon-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem;
  }

  .paimon-hero__actions {
    margin-top: 1.5rem;
  }

  .paimon-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 44px;
    padding: 0.62rem 1rem;
    border: 1px solid var(--paimon-line);
    border-radius: 999px;
    background: color-mix(in srgb, var(--ch-surface-solid) 72%, transparent);
    color: var(--ch-accent);
    font-family: var(--ch-academic-font);
    font-weight: 650;
    text-decoration: none;
    transition:
      transform var(--ch-transition-fast),
      border-color var(--ch-transition-fast),
      background var(--ch-transition-fast);
  }

  .paimon-link:hover,
  .paimon-link:focus-visible {
    border-color: color-mix(in srgb, var(--paimon-gold) 58%, var(--ch-border-soft));
    background: color-mix(in srgb, var(--ch-surface-solid) 86%, var(--ch-accent-dim));
    transform: translateY(-2px);
  }

  .paimon-link--primary {
    background: color-mix(in srgb, var(--paimon-gold) 20%, var(--ch-surface-solid));
    color: color-mix(in srgb, var(--ch-accent-ink) 78%, var(--paimon-gold));
  }

  .paimon-meta {
    margin: 1rem 0 0;
    padding: 0;
    list-style: none;
  }

  .paimon-meta li,
  .paimon-label,
  .paimon-pillar span,
  .paimon-evidence-chain span,
  .paimon-annotations span {
    font-family: var(--ch-mono-font);
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .paimon-meta li {
    padding: 0.24rem 0.52rem;
    border: 1px solid var(--ch-border-soft);
    border-radius: 999px;
    color: var(--ch-accent-secondary);
  }

  .paimon-hero__gallery {
    position: relative;
    z-index: 1;
  }

  .paimon-hero__visual,
  .paimon-map {
    margin: 0;
    overflow: hidden;
    border: 1px solid var(--paimon-line);
    border-radius: 12px;
    background: var(--ch-surface-solid);
  }

  .paimon-hero__visual {
    position: relative;
    aspect-ratio: 2048 / 680;
    box-shadow: 0 28px 90px color-mix(in srgb, var(--paimon-navy) 24%, transparent);
  }

  .paimon-hero__visual::after {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(90deg, color-mix(in srgb, var(--paimon-gold) 22%, transparent) 0 1px, transparent 1px 100%),
      linear-gradient(0deg, color-mix(in srgb, white 18%, transparent) 0 1px, transparent 1px 100%);
    background-size: 9rem 9rem;
    content: '';
    mix-blend-mode: screen;
    opacity: 0.22;
    pointer-events: none;
  }

  .paimon-hero__visual img,
  .paimon-map img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .paimon-exhibit-card {
