---
import GalleryImage from './GalleryImage.astro';
import { resolveGalleryImage, resolveGalleryImages } from '../utils/gallery-images';

interface Props {
  href: string;
  cover: string;
  title: string;
  description?: string;
  category: string;
  images: string[];
  imageDescs?: string[];
  date?: string;
  index: number;
  slug?: string;
}

const { href, cover, title, description, category, images, imageDescs = [], date, index, slug } = Astro.props;
const coverAsset = resolveGalleryImage(cover);
const imageAssets = resolveGalleryImages(images);

const categoryLabels: Record<string, string> = {
  illustration: '插画',
  photography: '摄影',
  design: '设计',
  'ui-ux': 'UI/UX',
  other: '其他',
};

const meta = {
  images: imageAssets,
  imageDescs,
  title,
  description: description ?? '',
  category,
  date: date ?? '',
  detailUrl: href,
};
---

<a
  href={href}
  class="gallery-card"
  data-category={category}
  data-gallery-slug={slug}
  data-gallery-meta={JSON.stringify(meta)}
  style={`animation-delay: ${index * 0.08}s`}
>
  <GalleryImage
    class="gallery-card__image"
    asset={coverAsset}
    alt={title}
    sizes="(max-width: 640px) 100vw, (max-width: 960px) 50vw, 33vw"
    loading={index === 0 ? 'eager' : 'lazy'}
    fetchpriority={index === 0 ? 'high' : 'auto'}
  />
  <span class="gallery-card__category">{categoryLabels[category] ?? category}</span>
  <div class="gallery-card__overlay">
    <h2 class="gallery-card__title">{title}</h2>
    {description && <p class="gallery-card__desc">{description}</p>}
  </div>
</a>
