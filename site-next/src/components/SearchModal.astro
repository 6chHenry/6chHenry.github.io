---
import ForestIcon from './ForestIcon.astro';
---

<div id="search-modal" class="search-modal" hidden>
  <div class="search-modal__backdrop" data-search-close></div>
  <div class="search-modal__panel card card--elevated" role="dialog" aria-modal="true" aria-label="站内搜索">
    <div class="search-modal__header">
      <div>
        <p class="search-modal__kicker">Search the grove</p>
        <h2>站内搜索</h2>
      </div>
      <button type="button" class="search-modal__close" data-search-close aria-label="关闭搜索">
        <ForestIcon name="close" />
      </button>
    </div>
    <div id="pagefind-search"></div>
  </div>
</div>

<style>
  .search-modal {
    position: fixed;
    inset: 0;
    z-index: 100;
    display: grid;
    place-items: start center;
    padding: 5rem 1.25rem 2rem;
  }

  .search-modal[hidden] {
    display: none;
  }

  .search-modal__backdrop {
    position: absolute;
    inset: 0;
    background: var(--ch-scrim);
    backdrop-filter: blur(6px);
  }

  .search-modal__panel {
    position: relative;
    width: min(100%, 44rem);
    padding: 1.25rem 1.35rem 1.35rem;
    animation: modal-in 0.28s cubic-bezier(0.22, 1, 0.36, 1) both;
  }

  @keyframes modal-in {
    from {
      opacity: 0;
      transform: translateY(-12px) scale(0.98);
    }
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  .search-modal__header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .search-modal__kicker {
    margin: 0 0 0.25rem;
    font-family: var(--ch-mono-font);
    font-size: 0.68rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--ch-accent-tertiary);
  }

  .search-modal__header h2 {
    margin: 0;
    font-family: var(--ch-display-font);
    font-size: 1.35rem;
    font-weight: 600;
    letter-spacing: 0.03em;
    color: var(--ch-accent);
  }

  .search-modal__close {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    width: 2.5rem;
    height: 2.5rem;
    border: 1px solid var(--ch-border-soft);
    border-radius: 12px;
    background: color-mix(in srgb, var(--ch-surface) 80%, transparent);
    color: var(--ch-accent-secondary);
    cursor: pointer;
    transition:
      color var(--ch-transition-fast),
      border-color var(--ch-transition-fast),
      background var(--ch-transition-fast),
      transform var(--ch-transition-fast);
  }

  .search-modal__close:hover,
  .search-modal__close:focus-visible {
    color: var(--ch-accent);
    border-color: color-mix(in srgb, var(--ch-accent-secondary) 45%, var(--ch-border));
    background: var(--ch-accent-dim);
    transform: translateY(-1px);
  }

  .search-modal__close:focus-visible {
    outline: 2px solid color-mix(in srgb, var(--ch-accent-tertiary) 55%, transparent);
    outline-offset: 2px;
  }

  .search-modal__close :global(.forest-icon) {
    width: 1.05rem;
    height: 1.05rem;
  }
</style>

<script>
  import { initSearchModal } from '../scripts/search';
  initSearchModal();
</script>
