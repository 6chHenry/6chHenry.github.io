---
import {
  FOREST_MAP_HEIGHT,
  FOREST_MAP_WIDTH,
  buildTrailPath,
  type ForestMapStop,
} from '../utils/forest-map';

interface Props {
  stops: ForestMapStop[];
}

const { stops } = Astro.props;

const trailPoints = stops.map((stop) => ({ x: stop.x, y: stop.y }));
const trailPath = buildTrailPath(trailPoints);
const firstDate = stops[0]?.dateLabel;
const lastDate = stops[stops.length - 1]?.dateLabel;

const collectionLabel: Record<string, string> = {
  notes: '笔记',
  essay: '杂谈',
  projects: '项目',
};

const bgTrees = [
  { x: 80, y: 420, s: 0.55 },
  { x: 210, y: 445, s: 0.72 },
  { x: 360, y: 410, s: 0.48 },
  { x: 520, y: 455, s: 0.65 },
  { x: 680, y: 405, s: 0.58 },
  { x: 840, y: 448, s: 0.7 },
  { x: 990, y: 415, s: 0.52 },
  { x: 1140, y: 440, s: 0.68 },
  { x: 1280, y: 425, s: 0.6 },
];
---

<section class="forest-map" aria-labelledby="forest-map-title">
  <div class="container forest-map__intro">
    <p class="section-kicker">Trail Map</p>
    <h2 id="forest-map-title" class="section-title">汉字森林 · 林径地图</h2>
    <p class="section-lead forest-map__lead">
      {
        firstDate && lastDate
          ? `从 ${firstDate} 到 ${lastDate}，沿时间走过的 ${stops.length} 处汉字树。最早与最新的笔记都在径上，其余为途中选点。`
          : '沿时间排列的汉字树，每一棵对应一篇笔记、杂谈或项目。'
      }
    </p>
  </div>

  <div class="forest-map__scroll">
    <div class="forest-map__stage" style={`--map-width: ${FOREST_MAP_WIDTH}; --map-height: ${FOREST_MAP_HEIGHT};`}>
      <svg
        class="forest-map__terrain"
        viewBox={`0 0 ${FOREST_MAP_WIDTH} ${FOREST_MAP_HEIGHT}`}
        preserveAspectRatio="xMidYMid meet"
        aria-hidden="true"
      >
        <defs>
          <linearGradient id="forest-map-sky" x1="0" y1="0" x2="0" y2="1">
            <stop offset="0%" stop-color="var(--ch-bg-sky)" stop-opacity="0.55" />
            <stop offset="55%" stop-color="var(--ch-bg-void)" stop-opacity="0.35" />
            <stop offset="100%" stop-color="var(--ch-bg-hill)" stop-opacity="0.45" />
          </linearGradient>
          <linearGradient id="forest-map-ground" x1="0" y1="0" x2="0" y2="1">
            <stop offset="0%" stop-color="var(--ch-accent-secondary)" stop-opacity="0.08" />
            <stop offset="100%" stop-color="var(--ch-accent)" stop-opacity="0.18" />
          </linearGradient>
          <filter id="forest-map-glow" x="-40%" y="-40%" width="180%" height="180%">
            <feGaussianBlur stdDeviation="3" result="blur" />
            <feMerge>
              <feMergeNode in="blur" />
              <feMergeNode in="SourceGraphic" />
            </feMerge>
          </filter>
        </defs>

        <rect width={FOREST_MAP_WIDTH} height={FOREST_MAP_HEIGHT} fill="url(#forest-map-sky)" />
        <path
          d={`M 0 ${FOREST_MAP_HEIGHT * 0.72} Q ${FOREST_MAP_WIDTH * 0.25} ${FOREST_MAP_HEIGHT * 0.58} ${FOREST_MAP_WIDTH * 0.5} ${FOREST_MAP_HEIGHT * 0.68} T ${FOREST_MAP_WIDTH} ${FOREST_MAP_HEIGHT * 0.74} L ${FOREST_MAP_WIDTH} ${FOREST_MAP_HEIGHT} L 0 ${FOREST_MAP_HEIGHT} Z`}
          fill="url(#forest-map-ground)"
        />

        {
          bgTrees.map((tree) => (
            <g transform={`translate(${tree.x} ${tree.y}) scale(${tree.s})`} opacity="0.22">
              <path
                d="M0 0 L12 -48 L24 0 L18 0 L30 -36 L42 0 L36 0 L48 28 L28 28 L28 72 L20 72 L20 28 L0 28 Z"
                fill="var(--ch-accent)"
              />
            </g>
          ))
        }

        {
          trailPath && (
            <>
              <path
                class="forest-map__trail forest-map__trail--shadow"
                d={trailPath}
                fill="none"
                stroke="var(--ch-accent)"
                stroke-width="10"
                stroke-linecap="round"
                stroke-linejoin="round"
                opacity="0.12"
              />
              <path
                class="forest-map__trail"
                d={trailPath}
                fill="none"
                stroke="var(--ch-accent-warm)"
                stroke-width="3"
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-dasharray="10 14"
                opacity="0.72"
              />
            </>
          )
        }

        {
          trailPoints.map((point, index) => (
            <circle
              class="forest-map__node-dot"
              cx={point.x}
              cy={point.y}
              r={index === 0 || index === trailPoints.length - 1 ? 5.5 : 4}
              fill="var(--ch-accent-warm)"
              opacity="0.85"
            />
          ))
        }

        <text x="72" y={FOREST_MAP_HEIGHT - 28} class="forest-map__edge-label">始</text>
        <text x={FOREST_MAP_WIDTH - 96} y={FOREST_MAP_HEIGHT - 28} class="forest-map__edge-label">今</text>
      </svg>

      <div class="forest-map__stops">
        {
          stops.map((stop, index) => {
            const left = (stop.x / FOREST_MAP_WIDTH) * 100;
            const top = (stop.y / FOREST_MAP_HEIGHT) * 100;
            const isEdge = index === 0 || index === stops.length - 1;
            const yearSide = stop.x > FOREST_MAP_WIDTH * 0.72 ? 'left' : 'right';
            const lift = index % 2 === 0 ? 72 : 64;

            return (
              <a
                class:list={['forest-map__stop', isEdge && 'forest-map__stop--edge']}
                style={`left: ${left}%; top: ${top}%; --stop-lift: ${lift}%;`}
                href={stop.href}
                title={`${stop.dateLabel} · ${stop.title}`}
              >
                <div class="forest-map__tree" aria-hidden="true">
                  <Fragment set:html={stop.treeSvg} />
                </div>
                <span class:list={['forest-map__date', `forest-map__date--${yearSide}`]}>{stop.dateLabel}</span>
                <span class="forest-map__stop-title">{stop.title}</span>
                <span class="forest-map__stop-kind">{collectionLabel[stop.collection] ?? stop.collection}</span>
              </a>
            );
          })
        }
      </div>
    </div>
  </div>
</section>
