---
import type { ForestMapData, ForestTreeNode } from '../utils/forest-map';

interface Props {
  stops: ForestMapData;
}

interface GroveView {
  collection: string;
  index: string;
  label: string;
  title: string;
  desc: string;
  coordinate: string;
  terrainLabel: string;
  href: string;
  count: number;
  x: number;
  y: number;
  trees: ForestTreeNode[];
  recentTrail: ForestTreeNode[];
}

const { stops } = Astro.props;
const base = import.meta.env.BASE_URL;

const groveConfig = [
  {
    collection: 'notes',
    index: '01',
    label: 'Notes Grove',
    title: '笔记林',
    desc: '课程、研究和技术路线沉积成主干。',
    coordinate: 'GRID 22 · 68',
    terrainLabel: '密林 / Rooted',
    href: `${base}notes/`,
    x: 22,
    y: 68,
  },
  {
    collection: 'essay',
    index: '02',
    label: 'Essay Grove',
    title: '杂谈林',
    desc: '旅行、生活和自我观察保留季节感。',
    coordinate: 'GRID 72 · 28',
    terrainLabel: '草甸 / Seasonal',
    href: `${base}essay/`,
    x: 72,
    y: 28,
  },
  {
    collection: 'projects',
    index: '03',
    label: 'Project Grove',
    title: '项目林',
    desc: '原型、实验和工程实践长出新的枝条。',
    coordinate: 'GRID 52 · 59',
    terrainLabel: '林间地 / Making',
    href: `${base}projects/`,
    x: 52,
    y: 59,
  },
];

const sortRecentTrees = (trees: ForestTreeNode[]) =>
  [...trees].sort((a, b) => (b.timestamp ?? 0) - (a.timestamp ?? 0) || a.title.localeCompare(b.title, 'zh-CN'));

const groves: GroveView[] = groveConfig.map((grove) => {
  const collectionTrees = stops.trees.filter((tree) => tree.collection === grove.collection);
  const recentTrees = sortRecentTrees(collectionTrees).filter((tree) => tree.timestamp > 0);

  return {
    ...grove,
    count: collectionTrees.length,
    trees: recentTrees.filter((tree) => tree.treeSvg && tree.x !== undefined && tree.y !== undefined).slice(0, 11),
    recentTrail: recentTrees.slice(0, 6),
  };
});

const overviewTrail = stops.recentTrees.slice(0, 6);
---

<section class="forest-map" aria-labelledby="forest-map-title">
  <div class="container forest-map__intro">
    <p class="section-kicker">Forest Atlas</p>
    <h2 id="forest-map-title" class="section-title">汉字森林 · 林径地图</h2>
    <p class="section-lead forest-map__lead">
      把学习、旅行和作品收在同一片林里：有些念头长成树，有些经历留下路，回头看时便能沿着尾迹找回当时的风。
    </p>
  </div>

  <div class="container forest-map__panel" data-forest-map data-view="overview" data-active-grove="overview">
    <div class="forest-map__meadow">
      <div class="forest-map__skyline" aria-hidden="true"></div>

      <div class="forest-map__viewport" aria-live="polite">
        <svg class="forest-map__topography" viewBox="0 0 760 420" preserveAspectRatio="none" aria-hidden="true">
          <g class="forest-map__contours forest-map__contours--notes">
            <path d="M-38 386 C38 298 126 286 206 326 C284 364 308 448 332 486" />
            <path d="M-18 350 C58 278 132 274 194 304 C258 334 288 398 304 460" />
            <path d="M22 326 C82 282 138 282 184 306 C226 330 256 370 270 418" />
          </g>
          <g class="forest-map__contours forest-map__contours--essay">
            <path d="M468 -46 C556 2 646 0 802 84" />
            <path d="M444 -18 C540 34 628 34 786 116" />
            <path d="M472 24 C552 62 634 66 756 134" />
          </g>
          <g class="forest-map__contours forest-map__contours--projects">
            <path d="M284 218 C350 154 446 150 516 208 C580 262 564 348 494 380" />
            <path d="M316 224 C372 178 438 180 486 218 C530 254 520 314 478 340" />
            <path d="M350 232 C390 204 434 206 462 232 C488 256 482 292 456 310" />
          </g>
        </svg>

        <svg class="forest-map__path" viewBox="0 0 760 420" preserveAspectRatio="none" aria-hidden="true">
          <path
            class="forest-map__path-halo"
            d="M44 382 C82 342 116 330 160 314 C214 294 220 266 286 248 C346 232 372 254 420 226 C472 194 498 142 548 118 C606 90 656 86 712 56"
            fill="none"
          />
          <path
            class="forest-map__path-line"
            d="M44 382 C82 342 116 330 160 314 C214 294 220 266 286 248 C346 232 372 254 420 226 C472 194 498 142 548 118 C606 90 656 86 712 56"
            fill="none"
          />
          <path class="forest-map__path-branch" d="M420 226 C450 262 486 284 538 298" fill="none" />
        </svg>

        <div class="forest-map__overview" data-forest-overview>
          <div class="forest-map__sheet-mark" aria-hidden="true">
            <span>6CH / FIELD SHEET 01</span>
            <span>FOREST ARCHIVE · 2026</span>
          </div>

          <div class="forest-map__compass" aria-hidden="true">
            <span>N</span>
            <i></i>
          </div>

          <div class="forest-map__overview-copy">
            <span>林地索引 · FIELD INDEX</span>
            <h3>沿着生长留下的路</h3>
            <p>笔记偏向根系，杂谈保存季节，项目像新生的枝条。它们彼此分开，又被同一条林径牵连。</p>
          </div>

          <div class="forest-map__terrain" aria-hidden="true">
            <span class="forest-map__terrain-zone forest-map__terrain-zone--notes"></span>
            <span class="forest-map__terrain-zone forest-map__terrain-zone--essay"></span>
            <span class="forest-map__terrain-zone forest-map__terrain-zone--projects"></span>
          </div>

          <div class="forest-map__trailhead" aria-hidden="true">
            <i></i>
            <span>林口<br /><small>YOU ARE HERE</small></span>
          </div>

          <div class="forest-map__grove-landmarks" aria-label="内容林地">
            {
              groves.map((grove) => (
                <button
                  id={`forest-landmark-${grove.collection}`}
                  class={`forest-map__landmark forest-map__landmark--${grove.collection}`}
                  type="button"
                  data-grove-trigger={grove.collection}
                  style={`--landmark-x: ${grove.x}%; --landmark-y: ${grove.y}%;`}
                  aria-label={`进入${grove.title}，${grove.count} 棵树，${grove.desc}`}
                >
                  <span class="forest-map__landmark-index" aria-hidden="true">{grove.index}</span>
                  <span class="forest-map__landmark-copy">
                    <span class="forest-map__landmark-label">{grove.label}</span>
                    <strong>{grove.title}</strong>
                    <em>{grove.count} 棵树 · {grove.terrainLabel}</em>
                    <small>{grove.coordinate}</small>
                  </span>
                </button>
              ))
            }
          </div>
        </div>

        <button class="forest-map__back" type="button" data-forest-back>
          <span aria-hidden="true">←</span> 回到林径
        </button>

        {
          groves.map((grove) => (
            <div
              id={`forest-grove-${grove.collection}`}
              class:list={['forest-map__grove-view', `forest-map__grove-view--${grove.collection}`]}
              role="region"
              aria-labelledby={`forest-landmark-${grove.collection}`}
              aria-hidden="true"
              data-grove-panel={grove.collection}
              inert
            >
              <div class="forest-map__grove-caption">
                <span>{grove.label}</span>
                <h3>{grove.title}</h3>
                <p>{grove.desc}</p>
              </div>

              <div class="forest-map__treefield" aria-label={`${grove.title}文字树`}>
                {
                  grove.trees.map((tree, index) => (
                    <a
                      class="forest-map__tree-node"
                      href={tree.href}
                      aria-label={`${tree.title}${tree.dateLabel ? `，${tree.dateLabel}` : ''}`}
                      tabindex="-1"
                      style={`left: ${tree.x}%; top: ${tree.y}%; --tree-scale: ${tree.scale ?? 1}; --tree-delay: ${index * 34}ms;`}
                    >
                      <span class="forest-map__tree-art" set:html={tree.treeSvg}></span>
                      <span class="forest-map__tree-label">
                        <strong>{tree.title}</strong>
                        {tree.dateLabel && <small>{tree.dateLabel}</small>}
                      </span>
                    </a>
                  ))
                }
              </div>
            </div>
          ))
        }
      </div>
    </div>

    <aside class="forest-map__sidebar" aria-label="所选林地最近更新">
      <div class="forest-map__trail-panel forest-map__trail-panel--overview is-active" aria-hidden="false" data-grove-trail="overview">
        <div class="forest-map__trail-head">
          <span>尾迹</span>
          <h3>全站尾迹</h3>
          <strong>{overviewTrail.length} 片叶</strong>
        </div>

        <ol>
          {
            overviewTrail.map((tree) => (
              <li>
                <a href={tree.href}>
                  <span class="forest-map__leaf">{tree.recentRank}</span>
                  <div>
                    <strong>{tree.title}</strong>
                    <p>{tree.summary}</p>
                  </div>
                  {tree.dateLabel && <time>{tree.dateLabel}</time>}
                </a>
              </li>
            ))
          }
        </ol>
      </div>

      {
        groves.map((grove) => (
          <div
            class:list={['forest-map__trail-panel', `forest-map__trail-panel--${grove.collection}`]}
            aria-hidden="true"
            data-grove-trail={grove.collection}
            inert
          >
            <div class="forest-map__trail-head">
              <span>{grove.label}</span>
              <h3>{grove.title}尾迹</h3>
              <strong>{grove.recentTrail.length} 片叶</strong>
            </div>

            <ol>
              {
                grove.recentTrail.map((tree, trailIndex) => (
                  <li>
                    <a href={tree.href} tabindex="-1">
                      <span class="forest-map__leaf">{trailIndex + 1}</span>
                      <div>
                        <strong>{tree.title}</strong>
                        <p>{tree.summary}</p>
                      </div>
                      {tree.dateLabel && <time>{tree.dateLabel}</time>}
                    </a>
                  </li>
                ))
              }
            </ol>

            <a class="forest-map__open" href={grove.href} tabindex="-1">
              进入{grove.title}
            </a>
          </div>
        ))
      }
    </aside>
  </div>
</section>

<script>
  const forestMaps = document.querySelectorAll('[data-forest-map]');

  forestMaps.forEach((root) => {
    const buttons = Array.from(root.querySelectorAll('[data-grove-trigger]'));
    const backButtons = Array.from(root.querySelectorAll('[data-forest-back]'));
    const panels = Array.from(root.querySelectorAll('[data-grove-panel]'));
    const trails = Array.from(root.querySelectorAll('[data-grove-trail]'));

    const setFocusable = (scope, enabled) => {
      scope.querySelectorAll('a, button').forEach((node) => {
        if (enabled) {
          node.removeAttribute('tabindex');
        } else {
          node.setAttribute('tabindex', '-1');
        }
      });
    };

    const activateTrail = (target) => {
      trails.forEach((trail) => {
        const active = trail.getAttribute('data-grove-trail') === target;
        trail.classList.toggle('is-active', active);
        trail.setAttribute('aria-hidden', active ? 'false' : 'true');
        trail.toggleAttribute('inert', !active);
        setFocusable(trail, active);
      });
    };

    const activateOverview = () => {
      root.setAttribute('data-view', 'overview');
      root.setAttribute('data-active-grove', 'overview');

      backButtons.forEach((button) => {
        button.setAttribute('tabindex', '-1');
      });

      buttons.forEach((button) => {
        button.classList.remove('is-active');
        button.removeAttribute('aria-current');
        button.removeAttribute('tabindex');
      });

      panels.forEach((panel) => {
        panel.classList.remove('is-active');
        panel.setAttribute('aria-hidden', 'true');
        panel.toggleAttribute('inert', true);
        setFocusable(panel, false);
      });

      activateTrail('overview');
    };

    const activateGrove = (grove) => {
      root.setAttribute('data-view', 'grove');
      root.setAttribute('data-active-grove', grove);

      backButtons.forEach((button) => {
        button.removeAttribute('tabindex');
      });

      buttons.forEach((button) => {
        const active = button.getAttribute('data-grove-trigger') === grove;
        button.classList.toggle('is-active', active);
        button.toggleAttribute('aria-current', active);
        button.removeAttribute('tabindex');
      });

      panels.forEach((panel) => {
        const active = panel.getAttribute('data-grove-panel') === grove;
        panel.classList.toggle('is-active', active);
        panel.setAttribute('aria-hidden', active ? 'false' : 'true');
        panel.toggleAttribute('inert', !active);
        setFocusable(panel, active);
      });

      activateTrail(grove);
    };

    buttons.forEach((button, index) => {
      button.addEventListener('click', () => {
        const grove = button.getAttribute('data-grove-trigger');
        if (grove) activateGrove(grove);
      });

      button.addEventListener('keydown', (event) => {
        if (event.key !== 'ArrowRight' && event.key !== 'ArrowLeft') return;
        event.preventDefault();
        const direction = event.key === 'ArrowRight' ? 1 : -1;
        const next = buttons[(index + direction + buttons.length) % buttons.length];
        if (next instanceof HTMLElement) next.focus();
      });
    });

    backButtons.forEach((button) => {
      button.addEventListener('click', activateOverview);
    });

    activateOverview();
  });
</script>
