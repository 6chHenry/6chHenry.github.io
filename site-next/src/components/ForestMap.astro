---
import {
  FOREST_MAP_HEIGHT,
  FOREST_MAP_WIDTH,
  buildCurvePath,
  type ForestMapData,
} from '../utils/forest-map';

interface Props {
  stops: ForestMapData;
}

const { stops } = Astro.props;
const recentPath = buildCurvePath(stops.recentTrees);

const groves = [
  { title: 'Notes Grove', x: 154, y: 92 },
  { title: 'Essay Grove', x: 780, y: 156 },
  { title: 'Project Grove', x: 484, y: 610 },
];
---

<section class="forest-map" aria-labelledby="forest-map-title">
  <div class="container forest-map__intro">
    <p class="section-kicker">Trail Map</p>
    <h2 id="forest-map-title" class="section-title">汉字森林 · 林径地图</h2>
    <p class="section-lead forest-map__lead">
      每棵树都是一篇内容。树冠来自文章里的汉字，大小随内容体量与更新时间变化；金色小径标出最近更新，并直接摘出标题。
    </p>
  </div>

  <div class="forest-map__scroll">
    <div class="forest-map__stage" style={`--map-width: ${FOREST_MAP_WIDTH}; --map-height: ${FOREST_MAP_HEIGHT};`}>
      <svg
        class="forest-map__terrain"
        viewBox={`0 0 ${FOREST_MAP_WIDTH} ${FOREST_MAP_HEIGHT}`}
        preserveAspectRatio="xMidYMid meet"
        aria-hidden="true"
      >
        <defs>
          <linearGradient id="forest-map-sky" x1="0" y1="0" x2="0" y2="1">
            <stop offset="0%" stop-color="var(--ch-bg-sky)" stop-opacity="0.52" />
            <stop offset="62%" stop-color="var(--ch-surface-solid)" stop-opacity="0.78" />
            <stop offset="100%" stop-color="var(--ch-bg-hill)" stop-opacity="0.42" />
          </linearGradient>
          <radialGradient id="forest-map-glade" cx="50%" cy="48%" r="52%">
            <stop offset="0%" stop-color="var(--ch-accent-light)" stop-opacity="0.18" />
            <stop offset="100%" stop-color="var(--ch-accent)" stop-opacity="0" />
          </radialGradient>
          <filter id="forest-map-path-glow" x="-40%" y="-40%" width="180%" height="180%">
            <feGaussianBlur stdDeviation="4" result="blur" />
            <feMerge>
              <feMergeNode in="blur" />
              <feMergeNode in="SourceGraphic" />
            </feMerge>
          </filter>
        </defs>

        <rect width={FOREST_MAP_WIDTH} height={FOREST_MAP_HEIGHT} rx="28" fill="url(#forest-map-sky)" />
        <rect width={FOREST_MAP_WIDTH} height={FOREST_MAP_HEIGHT} rx="28" fill="url(#forest-map-glade)" />
        <path
          d="M0 548 C170 476 302 594 468 520 C636 445 748 560 920 488 C1060 430 1164 478 1280 430 L1280 720 L0 720 Z"
          fill="var(--ch-accent)"
          opacity="0.08"
        />
        <path
          d="M0 612 C190 560 320 646 520 588 C710 532 876 640 1080 566 C1168 534 1224 526 1280 530 L1280 720 L0 720 Z"
          fill="var(--ch-accent-secondary)"
          opacity="0.08"
        />

        {
          groves.map((grove) => (
            <text x={grove.x} y={grove.y} class="forest-map__grove-label">
              {grove.title}
            </text>
          ))
        }

        {
          recentPath && (
            <>
              <path
                d={recentPath}
                class="forest-map__recent-path forest-map__recent-path--halo"
                fill="none"
                stroke="var(--ch-accent-warm)"
                stroke-width="12"
                stroke-linecap="round"
                stroke-linejoin="round"
                opacity="0.13"
              />
              <path
                d={recentPath}
                class="forest-map__recent-path"
                fill="none"
                stroke="var(--ch-accent-warm)"
                stroke-width="3"
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-dasharray="8 12"
                filter="url(#forest-map-path-glow)"
                opacity="0.84"
              />
            </>
          )
        }
      </svg>

      <div class="forest-map__canopy" aria-label="内容树林">
        {
          stops.trees.map((tree) => (
            <a
              class:list={['forest-map__tree', `forest-map__tree--${tree.collection}`, tree.recentRank && 'is-recent']}
              href={tree.href}
              aria-label={`${tree.title}${tree.dateLabel ? `，${tree.dateLabel}` : ''}`}
              style={`left: ${(tree.x / FOREST_MAP_WIDTH) * 100}%; top: ${(tree.y / FOREST_MAP_HEIGHT) * 100}%; --tree-scale: ${tree.size.toFixed(3)};`}
            >
              <span class="forest-map__tree-art" set:html={tree.treeSvg}></span>
              {tree.recentRank && <span class="forest-map__rank">{tree.recentRank}</span>}
              <span class="forest-map__preview">
                <span class="forest-map__preview-kicker">
                  {tree.dateLabel ?? (tree.collection === 'notes' ? 'Notes' : tree.collection === 'essay' ? 'Essay' : 'Project')}
                </span>
                <strong>{tree.title}</strong>
                <span>{tree.summary}</span>
              </span>
            </a>
          ))
        }
      </div>

      <div class="forest-map__recent-labels" aria-label="最近更新路径">
        {
          stops.recentTrees.map((tree, index) => (
            <a
              class="forest-map__recent-title"
              href={tree.href}
              style={`left: ${(tree.x / FOREST_MAP_WIDTH) * 100}%; top: ${(tree.y / FOREST_MAP_HEIGHT) * 100}%; --label-shift: ${index % 2 === 0 ? '-1' : '1'};`}
            >
              <span>{tree.recentRank}</span>
              <strong>{tree.title}</strong>
            </a>
          ))
        }
      </div>
    </div>
  </div>
</section>
