---
import BaseLayout from './BaseLayout.astro';
import ArticleChrome from '../components/ArticleChrome.astro';
import CharacterTree from '../components/CharacterTree.astro';
import { formatDate } from '../utils/content';

interface ArticleNavLink {
  title: string;
  href: string;
  description?: string;
}

interface Props {
  title: string;
  description?: string;
  date?: Date;
  tags?: string[];
  headings?: Array<{ depth: number; slug: string; text: string }>;
  characterTreeSvg?: string;
  previous?: ArticleNavLink;
  next?: ArticleNavLink;
  immersive?: boolean;
}

const {
  title,
  description,
  date,
  tags = [],
  headings = [],
  characterTreeSvg,
  previous,
  next,
  immersive = false,
} = Astro.props;
const base = import.meta.env.BASE_URL;
const showAside = !immersive && (headings.length > 0 || characterTreeSvg);
---

<BaseLayout title={title} description={description}>
  <ArticleChrome />

  <article class:list={['container content-layout page-shell', { 'content-layout--immersive': immersive }]}>
    <div class="content-main card card--elevated content-article">
      {
        !immersive && (
          <header class="page-header">
            <h1>{title}</h1>
            {description && <p>{description}</p>}
          </header>
        )
      }

      {
        !immersive && (
          <div class="content-meta">
            {date && <time datetime={date.toISOString()}>{formatDate(date)}</time>}
            {
              tags.length > 0 && (
                <ul class="tag-list">
                  {
                    tags.map((tag) => (
                      <li>
                        <a href={`${base}tags/${encodeURIComponent(tag)}/`}>#{tag}</a>
                      </li>
                    ))
                  }
                </ul>
              )
            }
          </div>
        )
      }

      <div class="prose" data-pagefind-body>
        <slot />
      </div>

      {
        (previous || next) && (
          <nav class="article-nav" aria-label="文章导航">
            {
              previous ? (
                <a class="article-nav__link article-nav__link--prev" href={previous.href}>
                  <span class="article-nav__eyebrow">上一篇</span>
                  <strong>{previous.title}</strong>
                  {previous.description && <span>{previous.description}</span>}
                </a>
              ) : (
                <span class="article-nav__spacer" aria-hidden="true"></span>
              )
            }
            {
              next ? (
                <a class="article-nav__link article-nav__link--next" href={next.href}>
                  <span class="article-nav__eyebrow">下一篇</span>
                  <strong>{next.title}</strong>
                  {next.description && <span>{next.description}</span>}
                </a>
              ) : (
                <span class="article-nav__spacer" aria-hidden="true"></span>
              )
            }
          </nav>
        )
      }
    </div>

    {
      showAside && (
        <aside class="content-aside">
          {
            headings.length > 0 && (
              <div class="content-toc">
                <p class="content-toc__title">目录</p>
                <nav aria-label="Table of contents">
                  <ul>
                    {
                      headings.map((heading) => (
                        <li style={`margin-left: ${Math.max(0, heading.depth - 2) * 0.85}rem`}>
                          <a href={`#${heading.slug}`}>{heading.text}</a>
                        </li>
                      ))
                    }
                  </ul>
                </nav>
              </div>
            )
          }
          {characterTreeSvg && <CharacterTree svg={characterTreeSvg} label={`${title} · 汉字树`} />}
        </aside>
      )
    }
  </article>
</BaseLayout>

<style>
  .content-article {
    padding: 2rem 2.15rem 2.5rem;
    background: var(--ch-glass-bg);
    border: 1px solid var(--ch-glass-border);
    backdrop-filter: blur(var(--ch-glass-blur)) saturate(1.12);
    -webkit-backdrop-filter: blur(var(--ch-glass-blur)) saturate(1.12);
    box-shadow: none;
  }

  .content-layout--immersive {
    grid-template-columns: minmax(0, 1fr);
    width: min(calc(100% - 2rem), 76rem);
  }

  .content-layout--immersive .content-article {
    overflow: hidden;
    padding: 0;
    border-color: color-mix(in srgb, var(--ch-border) 70%, transparent);
    background: var(--ch-surface-solid);
  }

  .content-layout--immersive .article-nav {
    margin: 2.5rem 2.5rem 0;
    padding-bottom: 2.5rem;
  }

  @media (max-width: 640px) {
    .content-article {
      padding: 1.35rem 1.15rem 1.75rem;
    }

    .content-layout--immersive {
      width: 100%;
      padding-top: 0;
    }

    .content-layout--immersive .content-article {
      padding: 0;
      border-inline: 0;
      border-radius: 0;
    }

    .content-layout--immersive .article-nav {
      margin-inline: 1.15rem;
      padding-bottom: 1.75rem;
    }
  }
</style>
